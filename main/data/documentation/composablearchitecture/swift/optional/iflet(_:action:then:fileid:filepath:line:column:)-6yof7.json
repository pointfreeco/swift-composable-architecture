":"codeVoice"},{"type":"text","text":" out the child state, in which case the child feature would not"},{"type":"text","text":" "},{"type":"text","text":"be able to react to that action. That can cause subtle bugs."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It automatically cancels all child effects when it detects the child’s state is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"’d"},{"type":"text","text":" "},{"type":"text","text":"out."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Automatically ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":"s out child state when an action is sent for alerts and confirmation","type":"text"},{"text":" ","type":"text"},{"text":"dialogs.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"Reducer\/ifLet(_:action:destination:fileID:filePath:line:column:)-4ub6q"},{"type":"text","text":" for a more advanced operator suited"},{"type":"text","text":" "},{"type":"text","text":"to navigation."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/swift\/optional\/iflet(_:action:then:fileid:filepath:line:column:)-6yof7"]}],"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Swift\/Optional","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Swift\/Optional\/Reducer-Implementations"]]},"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/Reducer/Action":{"kind":"symbol","title":"Action","abstract":[{"text":"A type that holds all possible actions that cause the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArc