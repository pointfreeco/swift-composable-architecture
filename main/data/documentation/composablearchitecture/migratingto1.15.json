"name":"Note"},{"inlineContent":[{"text":"There are two ways to fix this. You can either open the closure explicitly instead of using","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Action.response"},{"text":" as a function:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["return client.fetch()","  .map { .response($0) }"],"type":"codeListing"},{"inlineContent":[{"text":"There is also an upcoming Swift feature that will fix this. You can enable it in an SPM package","type":"text"},{"text":" ","type":"text"},{"text":"by adding a ","type":"text"},{"code":"enableUpcomingFeature","type":"codeVoice"},{"text":" to its Swift settings:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["swiftSettings: [","  .enableUpcomingFeature(\"InferSendableFromCaptures\"),","]),"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"And you can "},{"type":"reference","isActive":true,"identifier":"https:\/\/www.swift.org\/blog\/using-upcoming-feature-flags\/"},{"type":"text","text":" "},{"type":"text","text":"by navigating to your project’s build settings in Xcode, and adding a new “Other Swift Flags” flag:"}]},{"type":"codeListing","code":["-enable-upcoming-feature InferSendableFromCaptures"],"syntax":null}],"kind":"content"}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/WithViewStore":{"type":"topic","title":"WithViewStore","deprecated":true,"navigatorTitle":[{"text":"WithViewStore","kind":"identifier"}],"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/WithViewStore","url":"\/documentation\/composablearchitecture\/withviewstore","kind":"symbol","role":"symbol","abstract":[{"text":"A view helper that transforms a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store"},{"text":" into a ","type":"text"},{"isActive":true,"type":"reference","identifier"