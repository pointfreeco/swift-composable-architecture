ble key path from parent state to a property containing optional"},{"type":"text","text":" "},{"text":"child state.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"A case path from parent action to a case containing child actions."}],"type":"paragraph"}],"name":"toWrappedAction"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A reducer that will be invoked with child actions against non-optional child"},{"text":" ","type":"text"},{"type":"text","text":"state."}]}],"name":"wrapped"},{"content":[{"inlineContent":[{"type":"text","text":"The fileID."}],"type":"paragraph"}],"name":"fileID"},{"name":"filePath","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The filePath."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The line."}],"type":"paragraph"}],"name":"line"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The column."}]}],"name":"column"}]},{"content":[{"type":"heading","anchor":"return-value","text":"Return Value","level":2},{"inlineContent":[{"text":"A reducer that combines the child reducer with the parent reducer.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"For example, if a parent feature holds onto a piece of optional child state, then it can","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"perform its core logic "},{"inlineContent":[{"type":"text","text":"and"}],"type":"emphasis"},{"type":"text","text":" the child’s logic by using the "},{"type":"codeVoice","code":"ifLet"},{"text":" operator:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["@Reducer","struct Parent {","  struct State {","    var child: Child.State?","    \/\/ ...","  }","  enum Action {","    case child(Child.Action)","    \/\/ ...","  }","","  var body: some Reducer<State, Action> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .ifLet(\\.child, action: \\.child) {","      Child()","    }","  }","}"]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"ifLet"},{"text":" operator does a number of things to try to enforce correctness:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"It forces a specific order of operations for the child and parent features. It runs the","type":"text"},{"type":"text","text":" "},{"text":"child first, and then the parent. If the order was reversed, then it would be possible for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the parent feature to "},{"type":"codeVoice","code":"nil"},{"text":" out the child state, in which case the child feature would not","type":"text"},{"type":"text","text":" "},{"text":"be able to react to that action. That can cause subtle bugs.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It automatically cancels all child effects when it detects the child’s state is "},{"type":"codeVoice","code":"nil"},{"text":"’d","type":"text"},{"type":"text","text":" "},{"type":"text","text":"out."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Automatically "},{"type":"codeVoice","code":"nil"},{"text":"s out child state when an action is sent for alerts and confirmation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"dialogs."}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"See "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer\/ifLet(_:action:destination:fileID:filePath:line:column:)-4ub6q","isActive":true,"type":"reference"},{"text":" for a more advanced operator suited","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to navigation."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"patch"