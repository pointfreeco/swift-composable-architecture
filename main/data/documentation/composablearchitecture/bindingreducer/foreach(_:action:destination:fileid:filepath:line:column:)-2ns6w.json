t":" : ","kind":"text"},{"kind":"typeIdentifier","text":"Reducer","preciseIdentifier":"s:22ComposableArchitecture7ReducerP","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer"},{"kind":"text","text":"\n"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A writable key path from parent state to a stack of destination state.","type":"text"}]}],"name":"toStackState"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A case path from parent action to a stack action."}]}],"name":"toStackAction"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A reducer that will be invoked with destination actions against elements of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"destination state."}]}],"name":"destination"},{"content":[{"inlineContent":[{"text":"The fileID.","type":"text"}],"type":"paragraph"}],"name":"fileID"},{"name":"filePath","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The filePath."}]}]},{"name":"line","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The line."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The column."}],"type":"paragraph"}],"name":"column"}]},{"content":[{"level":2,"anchor":"return-value","type":"heading","text":"Return Value"},{"inlineContent":[{"text":"A reducer that combines the destination reducer with the parent reducer.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This version of "},{"code":"forEach","type":"codeVoice"},{"type":"text","text":" works when the parent domain holds onto the child domain using"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackState","type":"reference"},{"text":" and ","type":"text"},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction","isActive":true},{"text":".","type":"text"}]},{"inlineContent":[{"text":"For example, if a parent feature models a navigation stack of child features using the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackState","type":"reference"},{"text":" and ","type":"text"},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction","isActive":true},{"type":"text","text":" types, then it can perform its core logic "},{"type":"emphasis","inlineContent":[{"text":"and","type":"text"}]},{"type":"text","text":" the logic"},{"text":" ","type":"text"},{"text":"of each child feature using the ","type":"text"},{"type":"codeVoice","code":"forEach"},{"type":"text","text":" operator:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@Reducer","struct ParentFeature {","  struct State {","    var path = StackState<Path.State>()","    \/\/ ...","  }","  enum Action {","    case path(StackActionOf<Path>)","    \/\/ ...","  }","  var body: some ReducerOf<Self> {","    Reduce { state, action in","      \/\/ Core parent logic","    }","    .forEach(\\.path, action: \\.path) {","      Path()","    }","  }","}"]},{"inlineContent":[{"text":"The ","type":"text"},{"code":"forEach","type":"codeVoice"},{"text":" operator does a number of things to make integrating parent and child features","type":"text"},{"type":"text","text":" "},{"text":"ergonomic and enforce correctness:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"It forces a specific order of operations for the child and parent features:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"text":"When a ","type":"text"},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction\/element(id:action:)","isActive":true},{"type":"text","text":" action is sent it runs the"},{"type":"text","text":" "},{"text":"child first, and then the parent. If the order was reversed, then it would be possible","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for the parent feature to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" out the child state, in which case the child feature"},{"text":" ","type":"text"},{"text":"would not be able to react to that action. That can cause subtle bugs.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"When a "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction\/popFrom(id:)","isActive":true},{"type":"text","text":" action is sent it runs the parent feature"},{"type":"text","text":" "},{"text":"before the child state is popped off the stack. This gives the parent feature an","type":"text"},{"type":"text","text":" "},{"text":"opportunity to inspect the child state one last time before the state is removed.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"When a "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction\/push(id:state:)","isActive":true},{"type":"text","text":" action is sent it runs the parent feature"},{"type":"text","text":" "},{"text":"after the child state is appended to the stack. This gives the parent feature an","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"opportunity to make extra mutations to the state after it has been added."}],"type":"paragraph"}]}],"type":"unorderedList"}]},{"content":[{"inlineContent":[{"type":"text","text":"It automatically cancels all child effects when it detects the child’s state is removed"},{"text":" ","type":"text"},{"type":"text","text":"from the stack"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"It gives the child feature access to the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/DismissEffect"},{"text":" dependency, which allows the","type":"text"},{"text":" ","type":"text"},{"text":"child feature to dismiss itself without communicating with the parent.","type":"text"}]}]}],"type":"unorderedList"}]}],"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/BindingReducer","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/BindingReducer\/Reducer-Implementations"],["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/SwiftUIIntegration","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/BindingReducer","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/BindingReducer\/Reducer-Implementations"]]},"metadata":{"externalID":"s:22ComposableArchitecture7ReducerPAAE7forEach_6action11destination6fileID0H4Path4line6columnQrs011WritableKeyJ0Cy5StateQzAA05StackO0Vyqd__GG_s0nJ0Cy9CasePaths0Q0Vy6ActionQzGAWyAA0pS0Oyqd__qd_0_GGGqd_1_yXEs12StaticStringVA5_S2utAMQyd_1_Rsd__AXQyd_1_Rsd_0_AaBRd_1_r1_lF::SYNTHESIZED::s:22ComposableArchitecture14BindingReducerV","roleHeading":"Instance Method","extendedModule":"ComposableArchitecture","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"forEach","kind":"identifier"},{"text":"<","kind":"text"},{"text":"DestinationState","kind":"genericParameter"},{"text":", ","kind":"text"},{"kind":"genericParameter","text":"DestinationAction"},{"kind":"tex