,"","  enum Action {","    case isCompleteToggled(Bool)","    case descriptionChanged(String)","  }","","  var body: some Reducer<State, Action> {","    \/\/ ...","  }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As well as a view with a domain-specific store:"}]},{"syntax":"swift","code":["struct TodoView: View {","  let store: StoreOf<Todo>","  var body: some View { \/* ... *\/ }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"For a parent domain to work with a collection of todos, it can hold onto this collection in","type":"text"},{"text":" ","type":"text"},{"text":"state:","type":"text"}]},{"syntax":"swift","code":["@Reducer","struct Todos {","  struct State: Equatable {","    var todos: IdentifiedArrayOf<Todo.State> = []","  }","  \/\/ ...","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Define a case to handle actions sent to the child domain:"}]},{"syntax":"swift","code":["enum Action {","  case todos(IdentifiedActionOf<Todo>)","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Enhance its core reducer using"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer\/forEach(_:action:element:fileID:filePath:line:column:)-6zye8","type":"reference"},{"type":"text","text":":"}]},{"syntax":"swift","code":["var body: some Reducer<State, Action> {","  Reduce { state, action in","    \/\/ ...","  }","  .forEach(\\.todos, action: \\.todos) {","    Todo()","  }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"And finally render a list of ","type":"text"},{"type":"codeVoice","code":"TodoView"},{"text":"s using ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/ForEachStore","type":"reference","isActive":true},{"text":":","type":"text"}]},{"syntax":"swift","code":["ForEachS