{"kind":"article","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/migratingto1.13"]}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"The Composable Architecture is now integrated with the ","type":"text"},{"type":"reference","isActive":true,"identifier":"http:\/\/github.com\/pointfreeco\/swift-navigation"},{"text":" library,","type":"text"},{"text":" ","type":"text"},{"text":"which brings powerful navigation and observation tools to UIKit. You can model your domains","type":"text"},{"type":"text","text":" "},{"type":"text","text":"as concisely as possible, just as you would in SwiftUI, but then implement your view in UIKit"},{"type":"text","text":" "},{"text":"without losing any power.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The simplest tool to use is ","type":"text"},{"code":"observe","type":"codeVoice"},{"type":"text","text":", which allows you to minimally observe changes to state in"},{"type":"text","text":" "},{"text":"your feature and update the UI. Typically the best place to do this is in ","type":"text"},{"type":"codeVoice","code":"viewDidLoad"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["let store: StoreOf<Feature>","","func viewDidLoad() {","  super.viewDidLoad()","","  \/\/ ...","","  observe { [weak self] in","    countLabel.text = \"Count: \\(store.count)\"","  }","}"]},{"type":"paragraph","inlineContent":[{"text":"Only the state accessed in the ","type":"text"},{"type":"codeVoice","code":"observe"},{"type":"text","text":" trailing closure will be observed. If any other state"},{"type":"text","text":" "},{"text":"changes, the closure will not be invoked and no extra work will be performed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The library also provides powerful navigation tools for UIKit. For example, suppose you have a"},{"type":"text","text":" "},{"text":"feature that can present a child feature (see the docs on ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/TreeBasedNavigation","overridingTitleInlineContent":[{"type":"text","text":"tree-based"},{"text":" ","type":"text"},{"text":"navigation","type":"text"}],"overridingTitle":"tree-based navigation"},{"type":"text","text":" for more information on these tools):"}]},{"code":["@Reducer ","struct Feature {","  @ObservableState","  struct State {","    @Presents var child: ChildFeature.State?","    \/\/ ...","  }","  \/\/ ...","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Then you can present a view controller when the child state flips to a non-","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" value by using the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"present(item:)"},{"type":"text","text":" API that comes with the library:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@UIBindable var store: StoreOf<Feature>","","func viewDidLoad() {","  super.viewDidLoad()","","  present(item: $store.scope(state: \\.child, action: \\.child)) { store in","    ChildViewController(store: store)","  }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Further, if your feature has a stack of features that can be presented, then you can model your"},{"type":"text","text":" "},{"text":"domain like so (see the docs on ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackBasedNavigation","overridingTitleInlineContent":[{"type":"text","text":"stack-based"}],"overridingTitle":"stack-based"},{"type":"text","text":" for more information"},{"type":"text","text":" "},{"text":"on these tools):","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["@Reducer","struct AppFeature {","  struct State {","    var path = StackState<Path.State>()","    \/\/ ...","  }","","  @Reducer","  enum Path {","    case addItem(AddFeature)","    case detailItem(DetailFeature)","    case editItem(EditFeature)","  }","","  \/\/ ...","}"]},{"type":"paragraph","inlineContent":[{"text":"And for the view you can subclass ","type":"text"},{"code":"NavigationStackController","type":"codeVoice"},{"text":" in order to drive navigation from the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"stack state:"}]},{"type":"codeListing","syntax":"swift","code":["class AppController: NavigationStackController {","  private var store: StoreOf<AppFeature>!","","  convenience init(store: StoreOf<AppFeature>) {","    @UIBindable var store = store","","    self.init(path: $store.scope(state: \\.path, action: \\.path)) {","      RootViewController(store: store)","    } destination: { store in ","      switch store.case {","      case .addItem(let store):","        AddViewController(store: store)","      case .detailItem(let store):","        DetailViewController(store: store)","      case .editItem(let store):","        EditViewController(store: store)","      }","    }","","    self.store = store","  }","}"]}]}],"abstract":[{"text":"The Composable Architecture now provides first class tools for building features in UIKit,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"including minimal state observation, presentation and stack navigation."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17.1","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.16","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingT