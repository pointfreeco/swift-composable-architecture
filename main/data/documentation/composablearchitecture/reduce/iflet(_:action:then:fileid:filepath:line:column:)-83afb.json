,{"content":[{"type":"heading","anchor":"return-value","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A reducer that combines the child reducer with the parent reducer."}]}],"kind":"content"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, if a parent feature holds onto a piece of optional child state, then it can"},{"type":"text","text":" "},{"type":"text","text":"perform its core logic "},{"type":"emphasis","inlineContent":[{"text":"and","type":"text"}]},{"type":"text","text":" the child’s logic by using the "},{"type":"codeVoice","code":"ifLet"},{"type":"text","text":" operator:"}]},{"code":["@Reducer","struct Parent {","  struct State {","    var child: Child.State?","    \/\/ ...","  }","  enum Action {","    case child(Child.Action)","    \/\/ ...","  }","","  var body: some Reducer<State, Action> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .ifLet(\\.child, action: \\.child) {","      Child()","    }","  }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"ifLet","type":"codeVoice"},{"type":"text","text":" operator does a number of things to try to enforce correctness:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"It forces a specific order of operations for the child and parent features. It runs the","type":"text"},{"text":" ","type":"text"},{"text":"child first, and then the parent. If the order was reversed, then it would be possible for","type":"text"},{"text":" ","type":"text"},{"text":"the parent feature to ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" out the child state, in which case the child feature would not","type":"text"},{"text":" ","type":"text"},{"text":"be able to react to that action. That can cause subtle bugs.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It automatically cancels all child effects when it detects the child’s state is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"’d"},{"type":"text","text":" "},{"type":"text","text":"out."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Automatically "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"s out child state when an action is sent for alerts and confirmation"},{"type":"text","text":" "},{"type":"text","text":"dialogs."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer\/ifLet(_:action:destination:fileID:filePath:line:column:)-4ub6q"},{"text":" for a more advanced operator suited","type":"text"},{"text":" ","type":"text"},{"text":"to navigation.","type":"text"}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reduce\/ifLet(_:action:then:fileID:filePath:line:column:)-83afb"},"abstract":[{"type":"text","text":"Embeds a child reducer in a parent domain that works on an optional property of parent state."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reduce","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reduce\/Reducer-Implementations"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/Reducer/State":{"abstract":[{"type":"text","text":"A type that holds the current state of the reducer."}],"kind":"symbol","type":"topic","identifier":"doc:\/\/ComposableArchitectur