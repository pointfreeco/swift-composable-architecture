":["struct TodoView: View {","  let store: StoreOf<Todo>","  var body: some View { \/* ... *\/ }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"For a parent domain to work with a collection of todos, it can hold onto this collection in","type":"text"},{"text":" ","type":"text"},{"text":"state:","type":"text"}]},{"code":["@Reducer","struct Todos {","  struct State: Equatable {","    var todos: IdentifiedArrayOf<Todo.State> = []","  }","  \/\/ ...","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Define a case to handle actions sent to the child domain:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["enum Action {","  case todos(IdentifiedActionOf<Todo>)","}"]},{"type":"paragraph","inlineContent":[{"text":"Enhance its core reducer using","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer\/forEach(_:action:element:fileID:filePath:line:column:)-6zye8"},{"text":":","type":"text"}]},{"code":["var body: some Reducer<State, Action> {","  Reduce { state, action in","    \/\/ ...","  }","  .forEach(\\.todos, action: \\.todos) {","    Todo()","  }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"And finally render a list of "},{"type":"codeVoice","code":"TodoView"},{"type":"text","text":"s using "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/ForEachStore","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["ForEachStore(","  self.store.scope(state: \\.todos, action: \\.todos)",") { todoStore in","  TodoView(store: todoStore)","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/ComposableArchitecture\/s8CopyableP","doc:\/\/ComposableArchitecture\/s8Sendabl