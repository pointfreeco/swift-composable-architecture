"text"},{"text":" ","type":"text"},{"text":"effects. For example, if you start an effect (","type":"text"},{"type":"emphasis","inlineContent":[{"text":"e.g.","type":"text"}]},{"text":", a location manager) in ","type":"text"},{"type":"codeVoice","code":"onAppear"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"text","text":"forget to tear down the effect in "},{"type":"codeVoice","code":"onDisappear"},{"text":", the instrument will show that the effect","type":"text"},{"type":"text","text":" "},{"type":"text","text":"never completed."}]}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/CombineReducers\/signpost(_:log:)"},"kind":"symbol","abstract":[{"text":"Instruments a reducer with","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/os\/logging\/recording_performance_data","type":"reference"},{"type":"text","text":"."}],"references":{"https://developer.apple.com/documentation/os/logging/recording_performance_data":{"title":"signposts","type":"link","titleInlineContent":[{"type":"text","text":"signposts"}],"url":"https:\/\/developer.apple.com\/documentation\/os\/logging\/recording_performance_data","identifier":"https:\/\/developer.apple.com\/documentation\/os\/logging\/recording_performance_data"},"doc://ComposableArchitecture/documentation/ComposableArchitecture/Effect":{"role":"symbol","navigatorTitle":[{"text":"Effect","kind":"identifier"}],"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Effect","type":"topic","kind":"symbol","title":"Effect","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"Effect","kind":"identifier"}],"abstract":[],"url":"\/documentation\/composablearchitecture\/effect"},"doc://ComposableArchitecture/documentation/ComposableArchitecture/Reducer":{"fragments":[{"text"