ComposableArchitecture\/Reducer","preciseIdentifier":"s:22ComposableArchitecture7ReducerP"},{"text":"\n","kind":"text"}],"platforms":["macOS"]}]},{"parameters":[{"name":"toElementsState","content":[{"inlineContent":[{"text":"A writable key path from parent state to an ","type":"text"},{"type":"codeVoice","code":"IdentifiedArray"},{"text":" of child","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A case path from parent action to an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/IdentifiedAction"},{"type":"text","text":" of child"},{"text":" ","type":"text"},{"type":"text","text":"actions."}]}],"name":"toElementAction"},{"name":"element","content":[{"inlineContent":[{"type":"text","text":"A reducer that will be invoked with child actions against elements of child"},{"text":" ","type":"text"},{"type":"text","text":"state."}],"type":"paragraph"}]},{"name":"fileID","content":[{"inlineContent":[{"type":"text","text":"The fileID."}],"type":"paragraph"}]},{"name":"filePath","content":[{"type":"paragraph","inlineContent":[{"text":"The filePath.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"The line.","type":"text"}],"type":"paragraph"}],"name":"line"},{"name":"column","content":[{"inlineContent":[{"type":"text","text":"The column."}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"A reducer that combines the child reducer with the parent reducer."}],"type":"paragraph"}],"kind":"content"},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"For example, if a parent feature holds onto an array of child states, then it can perform","type":"text"},{"type":"text","text":" "},{"text":"its core logic ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"and","type":"text"}]},{"text":" the child’s logic by using the ","type":"text"},{"type":"codeVoice","code":"forEach"},{"type":"text","text":" operator:"}],"type":"paragraph"},{"code":["@Reducer","struct Parent {","  struct State {","    var rows: IdentifiedArrayOf<Row.State>","    \/\/ ...","  }","  enum Action {","    case rows(IdentifiedActionOf<Row>)","    \/\/ ...","  }","","  var body: some Reducer<State, Action> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .forEach(\\.rows, action: \\.rows) {","      Row()","    }","  }","}"],"syntax":"swift","type":"codeListing"},{"style":"tip","type":"aside","name":"Tip","content":[{"inlineContent":[{"text":"We are using ","type":"text"},{"type":"codeVoice","code":"IdentifiedArray"},{"type":"text","text":" from our"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"http:\/\/github.com\/pointfreeco\/swift-identified-collections"},{"text":" library because it provides a safe","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and ergonomic API for accessing elements from a stable ID rather than positional indices."}],"type":"paragraph"}]},{"inlineContent":[{"type":"text","text":"The "},{"code":"forEach","type":"codeVoice"},{"text":" forces a specific order of operations for the child and parent features. It","type":"text"},{"type":"text","text":" "},{"type":"text","text":"runs the child first, and then the parent. If the order was reversed, then it would be"},{"text":" ","type":"text"},{"text":"possible for the parent feature to remove the child state from the array, in which case the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"child feature would not be able to react to that action. That can cause subtle bugs."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It is still possible for a parent feature higher up in the application to remove the child","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"state from the array before the child has a chance to react to the action. In such cases a"},{"type":"text","text":" "},{"type":"text","text":"runtime warning is shown in Xcode to let you know that there’s a potential problem."}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reduce","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reduce\/Reducer-Implementations"]]},"identifier":{"url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reduce\/forEach(_:action:element:fileID:filePath:line:column:)-4hrh1","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","abstract":[{"text":"Embeds a child reducer in a parent domain that works on elements of a collection in parent","type":"text"},{"type":"text","text":" "},{"text":"state.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/reduce\/foreach(_:action:element:fileid:filepath:line:column:)-4hrh1"]}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/Reducer":{"kind":"symbol","abstract":[{"text":"A protocol that describes how to evolve the current state of an application to the next state,","type":"text"},{"type":"text","text":" "},{"text":"given an action, and describes what ","type":"text"},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Effect","isActive":true},{"type":"text","text":"s should be executed later by the store, if any."}],"title":"Reducer","role":"symbol","navigatorTitle":[{"text":"Reducer","kind":"identifier"}],"identifier":"doc:\/\/ComposableArchitectu