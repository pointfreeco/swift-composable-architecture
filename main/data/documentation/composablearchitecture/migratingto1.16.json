{"variants":[{"paths":["\/documentation\/composablearchitecture\/migratingto1.16"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There are no steps needed to migrate to 1.16 of the Composable Architecture, but there has been"},{"type":"text","text":" "},{"type":"text","text":"a change to the underlying behavior of "},{"code":".appStorage","type":"codeVoice"},{"type":"text","text":" that one should be aware of. When using"},{"type":"text","text":" "},{"code":".appStorage","type":"codeVoice"},{"type":"text","text":" with "},{"code":"@Shared","type":"codeVoice"},{"type":"text","text":", if your key does not contain the characters “.” or “@”, then changes"},{"type":"text","text":" "},{"text":"to that key in ","type":"text"},{"type":"codeVoice","code":"UserDefaults"},{"text":" will be observed using key-value observing (KVO).","type":"text"},{"text":" ","type":"text"},{"text":"Otherwise, ","type":"text"},{"type":"codeVoice","code":"NotificationCenter"},{"text":" will be used to observe changes.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"KVO is a far more efficient way of observing changes to "},{"type":"codeVoice","code":"UserDefaults"},{"type":"text","text":" and it works cross-process,"},{"type":"text","text":" "},{"type":"text","text":"such as from widgets and app extensions. However, KVO does not work when the keys contain “.”"},{"type":"text","text":" "},{"type":"text","text":"or “@”, and so in those cases we must use the cruder tool of "},{"type":"codeVoice","code":"NotificationCenter"},{"type":"text","text":". That is not"},{"type":"text","text":" "},{"type":"text","text":"as efficient, and it forces us to perform a thread-hop when the notification is posted before"},{"type":"text","text":" "},{"type":"text","text":"we can update the "},{"type":"codeVoice","code":"@Shared"},{"type":"text","text":" value. For this reason it is not possible to animate changes that are"},{"type":"text","text":" "},{"type":"text","text":"made directly to "},{"type":"codeVoice","code":"UserDefaults"},{"type":"text","text":":"}]},{"syntax":"swift","code":["withAnimation {","  \/\/ ⚠️ This will not animate any SwiftUI views using '@Shared(.appStorage(\"co.pointfree.count\"))'","  UserDefaults.standard.set(0, forKey: \"co.pointfree.count\")","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In general, we recommend using other delimeters for your keys, such as “\/”, “:”, “-”, etc.:"}]},{"syntax":"swift","code":["@Shared(.appStorage(\"co:pointfree:count\")) var count = 0"],"type":"codeListing"}]}],"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigrationGuides"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","identifier":{"url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.16","interfaceLanguage":"swift"},"metadata":{"role":"article","title":"Migrating to 1.16","roleHeading":"Article","modules":[{"name":"ComposableArchitecture"}]},"seeAlsoSections":[{"identifiers":["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.19","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.18","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17.1","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.15","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.14","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.13","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.12","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.11","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.10","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.9","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.8","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.7","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.6","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.5","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.4"],"generated":true}],"abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":".appStorage"},{"text":" strategy used with ","type":"text"},{"type":"codeVoice","code":"@Shared"},{"text":" now uses key-value observing instead of","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NotificationCenter"},{"text":" when possible. Learn how this may affect your code.","type":"text"}],"sections":[],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/MigratingTo1.14":{"type":"topic","role":"article","kind":"article","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.14","abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store"},{"type":"text","text":" type is now officially "},{"type":"codeVoice","code":"@MainActor"},{"type":"text","text":" isolated."}],"title":"Migrating to 1.14","url":"\/documentation\/composablearchitecture\/migratingto1.14"},"doc://ComposableArchitecture/documentation/ComposableArchitecture/MigratingTo1.12":{"url":"\/documentation\/composablearchitecture\/migratingto1.12","type":"topic","identifier":"doc:\/\/Comp