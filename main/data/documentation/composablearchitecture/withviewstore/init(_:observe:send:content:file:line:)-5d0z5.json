icParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"store"},{"kind":"text","text":": "},{"text":"Store","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","preciseIdentifier":"s:22ComposableArchitecture5StoreC","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"State"},{"kind":"text","text":", "},{"text":"Action","kind":"typeIdentifier"},{"text":">, ","kind":"text"},{"kind":"externalParam","text":"observe"},{"kind":"text","text":" "},{"kind":"internalParam","text":"toViewState"},{"text":": ","kind":"text"},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","text":"State"},{"kind":"text","text":") -> "},{"text":"ViewState","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"send","kind":"externalParam"},{"kind":"text","text":" "},{"text":"fromViewAction","kind":"internalParam"},{"kind":"text","text":": "},{"text":"@escaping","kind":"keyword"},{"text":" (","kind":"text"},{"text":"ViewAction","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"Action","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"@","kind":"attribute"},{"kind":"attribute","text":"ViewBuilder","preciseIdentifier":"s:7SwiftUI11ViewBuilderV"},{"kind":"text","text":" "},{"kind":"externalParam","text":"content"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/ViewStore","text":"ViewStore","preciseIdentifier":"s:22ComposableArchitecture9ViewStoreC"},{"kind":"text","text":"<"},{"text":"ViewState","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"ViewAction","kind":"typeIdentifier"},{"text":">) -> ","kind":"text"},{"kind":"typeIdentifier","text":"Content"},{"kind":"text","text":", "},{"text":"file","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s12StaticStringV","text":"StaticString"},{"text":" = ","kind":"text"},{"text":"#fileID","kind":"keyword"},{"text":", ","kind":"text"},{"text":"line","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UInt","kind":"typeIdentifier","preciseIdentifier":"s:Su"},{"text":" = ","kind":"text"},{"text":"#line","kind":"keyword"},{"kind":"text","text":")"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"store","content":[{"type":"paragraph","inlineContent":[{"text":"A store.","type":"text"}]}]},{"name":"toViewState","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A function that transforms store state into observable view state. All"},{"text":" ","type":"text"},{"text":"changes to the view state will cause the ","type":"text"},{"type":"codeVoice","code":"WithViewStore"},{"text":" to re-compute its view.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A function that transforms view actions into store action.","type":"text"}]}],"name":"fromViewAction"},{"name":"content","content":[{"type":"paragraph","inlineContent":[{"text":"A function that can generate content from a view store.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The file."}],"type":"paragraph"}],"name":"file"},{"name":"line","content":[{"type":"paragraph","inlineContent":[{"text":"The line.","type":"text"}]}]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/WithViewStore","isActive":true},{"type":"text","text":" will re-compute its body for "},{"inlineContent":[{"type":"text","text":"any"}],"type":"emphasis"},{"type":"text","text":" change to the state it holds. Often the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","isActive":true},{"text":" that we want to observe holds onto a lot more state than is necessary to render a","type":"text"},{"text":" ","type":"text"},{"text":"view. It may hold onto the state of child features, or internal state for its logic.","type":"text"}]},{"inlineContent":[{"type":"text","text":"It can be important to transform the "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","isActive":true,"type":"reference"},{"type":"text","text":"’s state into something smaller for observation."},{"type":"text","text":" "},{"type":"text","text":"This will help minimize the number of times your view re-computes its body, and can even avoid"},{"type":"text","text":" "},{"type":"text","text":"certain SwiftUI bugs that happen due to over-rendering."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The way to do this is to use the "},{"type":"codeVoice","code":"observe"},{"text":" argument of this initializer. It allows you to","type":"text"},{"text":" ","type":"text"},{"text":"turn the full state into a smaller data type, and only changes to that data type will trigger","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a body re-computation."}],"type":"paragraph"},{"inlineContent":[{"text":"For example, if your application uses a tab view, then the root state may hold the state","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for each tab as well as the currently selected tab:"}],"type":"paragraph"},{"syntax":"swift","code":["@Reducer","struct AppFeature {","  enum Tab { case activity, search, profile }","  struct State {","    var activity: Activity.State","    var search: Search.State","    var profile: Profile.State","    var selectedTab: Tab","  }","  \/\/ ...","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to construct a tab view you need to observe this state because changes to"},{"type":"text","text":" "},{"type":"codeVoice","code":"selectedTab"},{"text":" need to make SwiftUI update the visual state of the UI. However, you do not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"need to observe changes to "},{"code":"activity","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"search"},{"type":"text","text":" and "},{"code":"profile","type":"codeVoice"},{"type":"text","text":". Those are only necessary for"},{"type":"text","text":" "},{"type":"text","text":"those child features, and changes to that state should not cause our tab view to re-compute"},{"type":"text","text":" "},{"text":"itself.","type":"text"}]},{"code":["struct AppView: View {","  let store: StoreOf<AppFeature>","","  var body: some View {","    WithViewStore(self.store, observe: \\.selectedTab) { viewStore in","      TabView(selection: viewStore.binding(send: { .tabSelected($0) }) {","        ActivityView(","          store: self.store.scope(state: \\.activity, action: \\.activity)","        )","        .tag(AppFeature.Tab.activity)","        SearchView(","          store: self.store.scope(state: \\.search, action: \\.search)","        )","        .tag(AppFeature.Tab.search)","        ProfileView(","          store: self.store.scope(state: \\.profile, action: \\.profile)","        )","        .tag(AppFeature.Tab.profile)","      }","    }","  }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To read more about this performance technique, read the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Performance"},{"text":" article.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/withviewstore\/init(_:observe:send:content:file:line:)-5d0z5"]}],"meta