{"kind":"article","variants":[{"paths":["\/documentation\/composablearchitecture\/migratingto1.16"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"title":"Migrating to 1.16","roleHeading":"Article","modules":[{"name":"ComposableArchitecture"}],"role":"article"},"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigrationGuides"]]},"abstract":[{"type":"text","text":"The "},{"code":".appStorage","type":"codeVoice"},{"text":" strategy used with ","type":"text"},{"type":"codeVoice","code":"@Shared"},{"text":" now uses key-value observing instead of","type":"text"},{"type":"text","text":" "},{"code":"NotificationCenter","type":"codeVoice"},{"text":" when possible. Learn how this may affect your code.","type":"text"}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.19","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.18","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17.1","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.15","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.14","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.13","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.12","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.11","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.10","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.9","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.8","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.7","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.6","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.5","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.4"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.16"},"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"There are no steps needed to migrate to 1.16 of the Composable Architecture, but there has been","type":"text"},{"type":"text","text":" "},{"text":"a change to the underlying behavior of ","type":"text"},{"type":"codeVoice","code":".appStorage"},{"text":" that one should be aware of. When using","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":".appStorage"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"@Shared"},{"text":", if your key does not contain the characters “.” or “@”, then changes","type":"text"},{"type":"text","text":" "},{"text":"to that key in ","type":"text"},{"type":"codeVoice","code":"UserDefaults"},{"text":" will be observed using key-value observing (KVO).","type":"text"},{"type":"text","text":" "},{"text":"Otherwise, ","type":"text"},{"type":"codeVoice","code":"NotificationCenter"},{"text":" will be used to observe changes.","type":"text"}]},{"inlineContent":[{"type":"text","text":"KVO is a far more efficient way of observing changes to "},{"code":"UserDefaults","type":"codeVoice"},{"text":" and it works cross-process,","type":"text"},{"text":" ","type":"text"},{"text":"such as from widgets and app extensions. However, KVO does not work when the keys contain “.”","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or “@”, and so in those cases we must use the cruder tool of "},{"type":"codeVoice","code":"NotificationCenter"},{"type":"text","text":". That is not"},{"type":"text","text":" "},{"type":"text","text":"as efficient, and it forces us to perform a thread-hop when the notification is posted before"},{"type":"text","text":" "},{"type":"text","text":"we can update the "},{"code":"@Shared","type":"codeVoice"},{"text":" value. For this reason it is not possible to animate changes that are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"made directly to "},{"type":"codeVoice","code":"UserDefaults"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["withAnimation {","  \/\/ ⚠️ This will not animate any SwiftUI views using '@Shared(.appStorage(\"co.pointfree.count\"))'","  UserDefaults.standard.set(0, forKey: \"co.pointfree.count\")","}"]},{"inlineContent":[{"text":"In general, we recommend using other delimeters for your keys, such as “\/”, “:”, “-”, etc.:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["@Shared(.appStorage(\"co:pointfree:count\")) var count = 0"],"syntax":"swift"}],"kind":"content"}],"sections":[],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/MigratingTo1.18":{"type":"topic","title":"Migrating to 1.18","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.18","role":"article","abstract":[{"type":"text","text":"Stores now automatically cancel their in-flight effects when they deallocate. And another UIKit"},{"text":" ","type":"text"},{"type":"text","text":"navigation helper has been introduced."}],"url":"\/documentation\/composablearchitecture\/migratingto1.18","kind":"article"},"doc://ComposableArchitecture/documentation/ComposableArchitecture/MigratingTo1.15":{"type":"topic","title":"Migrating to 1.15","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.15","role":"article","abstract":[{"type":"text","text":"The library has been completely updated for Swift 6 language mode, and now compiles in strict"},{"text":" ","type":"text"},{"type":"text","text":"concurrency with no warnings or errors."}],"url":"\/documentation\/composablearchitecture\/migratingto1.15","kind":"article"},"doc://ComposableArchitecture/documentation/ComposableArchitecture/MigratingTo1.17":{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17","type":"topic","kind":"article","role":"article","url":"\/documentation\/composablearchitecture\/migratingto1.17","title":"Migrating to 1.17","abstract":[{"text":"The ","type":"text"},{"code":"@Shared","type":"codeVoice"},{"type":"text","text":" property wrapper and related tools have been extracted to their own"},{"text":" ","type":"text"},{"type":"text","text":"library so that they can be used in non-Composable Architecture applications. This a"},{"text":" ","type":"text"},{"type":"text","text":"backwards compatible change, but some new deprecations have been introduced."}]},"doc://ComposableArchitecture/documentation/ComposableArchitecture/MigratingTo1.17.1":{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17.1","type":"topic","kind":"article","role":"article","url":"\/documentation\/composablearchitecture\/migratingto1.17.1","title":"Migrating to 1.17.1","abstract":[{"type":"text","text":"The Sharing library has graduated, with backwards-incompatible changes, to 2.0, and the Composable"},{"text":" ","type":"text"},{"type":"text","text":"Architecture has been updated to extend support to this new version."}]},"doc://ComposableArchitecture/documentation/ComposableArchitecture/MigratingTo1.19":{"type":"topic","title":"Migrating to 1.19","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.19","role":"article","abstract":[{"type":"text","text":"Store internals have been rewritten for performance and future