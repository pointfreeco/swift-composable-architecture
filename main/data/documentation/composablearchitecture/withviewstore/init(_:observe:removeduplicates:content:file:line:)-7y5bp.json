c:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/ViewStore","kind":"typeIdentifier","preciseIdentifier":"s:22ComposableArchitecture9ViewStoreC"},{"text":"<","kind":"text"},{"text":"ViewState","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ViewAction","kind":"typeIdentifier"},{"text":">) -> ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"file","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"StaticString","kind":"typeIdentifier","preciseIdentifier":"s:s12StaticStringV"},{"text":" = ","kind":"text"},{"text":"#fileID","kind":"keyword"},{"text":", ","kind":"text"},{"text":"line","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UInt","kind":"typeIdentifier","preciseIdentifier":"s:Su"},{"text":" = ","kind":"text"},{"text":"#line","kind":"keyword"},{"text":")","kind":"text"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A store."}]}],"name":"store"},{"content":[{"inlineContent":[{"text":"A function that transforms store state into observable view state. All","type":"text"},{"text":" ","type":"text"},{"text":"changes to the view state will cause the ","type":"text"},{"type":"codeVoice","code":"WithViewStore"},{"text":" to re-compute its view.","type":"text"}],"type":"paragraph"}],"name":"toViewState"},{"content":[{"inlineContent":[{"text":"A function to determine when two ","type":"text"},{"code":"ViewState","type":"codeVoice"},{"text":" values are equal. When values","type":"text"},{"text":" ","type":"text"},{"text":"are equal, repeat view computations are removed.","type":"text"}],"type":"paragraph"}],"name":"isDuplicate"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A function that can generate content from a view store."}]}],"name":"content"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The file."}]}],"name":"file"},{"content":[{"inlineContent":[{"text":"The line.","type":"text"}],"type":"paragraph"}],"name":"line"}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/WithViewStore"},{"type":"text","text":" will re-compute its body for "},{"type":"emphasis","inlineContent":[{"text":"any","type":"text"}]},{"type":"text","text":" change to the state it holds. Often the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store"},{"type":"text","text":" that we want to observe holds onto a lot more state than is necessary to render a"},{"type":"text","text":" "},{"type":"text","text":"view. It may hold onto the state of child features, or internal state for its logic."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It can be important to transform the "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","isActive":true},{"type":"text","text":"’s state into something smaller for observation."},{"type":"text","text":" "},{"type":"text","text":"This will help minimize the number of times your view re-computes its body, and can even avoid"},{"type":"text","text":" "},{"type":"text","text":"certain SwiftUI bugs that happen due to over-rendering."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The way to do this is to use the "},{"type":"codeVoice","code":"observe"},{"type":"text","text":" argument of this initializer. It allows you to"},{"type":"text","text":" "},{"type":"text","text":"turn the full state into a smaller data type, and only changes to that data type will trigger"},{"type":"text","text":" "},{"type":"text","text":"a body re-computation."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, if your application uses a tab view, then the root state may hold the state"},{"type":"text","text":" "},{"type":"text","text":"for each tab as well as the currently selected tab:"}]},{"type":"codeListing","syntax":"swift","code":["@Reducer","struct AppFeature {","  enum Tab { case activity, search, profile }","  struct State {","    var activity: Activity.State","    var search: Search.State","    var profile: Profile.State","    var selectedTab: Tab","  }","  \/\/ ...","}"]},{"type":"paragraph","inlineContent":[{"text":"In order to construct a tab view you need to observe this state because changes to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"selectedTab"},{"text":" need to make SwiftUI update the visual state of the UI. However, you do not","type":"text"},{"text":" ","type":"text"},{"text":"need to observe changes to ","type":"text"},{"type":"codeVoice","code":"activity"},{"text":", ","type":"text"},{"type":"codeVoice","code":"search"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"profile"},{"text":". Those are only necessary for","type":"text"},{"text":" ","type":"text"},{"text":"those child features, and changes to that state should not cause our tab view to re-compute","type":"text"},{"text":" ","type":"text"},{"text":"itself.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct AppView: View {","  let store: StoreOf<AppFeature>","","  var body: some View {","    WithViewStore(self.store, observe: \\.selectedTab) { viewStore in","      TabView(selection: viewStore.binding(send: { .tabSelected($0) }) {","        ActivityView(","          store: self.store.scope(state: \\.activity, action: \\.activity)","        )","        .tag(AppFeature.Tab.activity)","        SearchView(","          store: self.store.scope(state: \\.search, action: \\.search)","        )","        .tag(AppFeature.Tab.search)","        ProfileView(","          store: self.store.scope(state: \\.profile, action: \\.profile)","        )","        .tag(AppFeature.Tab.profile)","      }","    }","  }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To read more about this performance technique, read the "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Performance","isActive":true},{"type":"text","text":" article."}]}]}],"sections":[],"abstract":[{"type":"text","text":"Initializes a structure that transforms a "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","isActive":true},{"type":"text","text":" into an observable "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/ViewStore","isActive":true},{"type":"text","text":" in order"},{"type":"text","text":" "},{"type":"text","text":"to compute views from state."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/documentation\/composablearchitecture\/withviewstore\/init(_:observe:removeduplicates:content:file:line:)-7y5bp"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"Initializer","modules":[{"name":"ComposableArchitecture"}],"role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"State"},{"kind":"text","text":">("},{"kind":"typeIdentifier","preciseIdentifier":"s:22ComposableArchitecture5StoreC","text":"Store"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"State"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"ViewAction"},{"kind":"text","text":">, "},{"kind":"externalParam","text":"observe"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","text":"State"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"ViewState"},{"kind":"text","text":", "},{"kind":"externalParam","text":"removeDuplicates"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","text":"ViewState"},{"