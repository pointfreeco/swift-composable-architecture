e":"column","content":[{"inlineContent":[{"text":"The column.","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"type":"heading","text":"Return Value","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A reducer that combines the child reducer with the parent reducer."}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"For example, if a parent feature holds onto an array of child states, then it can perform","type":"text"},{"text":" ","type":"text"},{"text":"its core logic ","type":"text"},{"inlineContent":[{"text":"and","type":"text"}],"type":"emphasis"},{"text":" the child’s logic by using the ","type":"text"},{"code":"forEach","type":"codeVoice"},{"text":" operator:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["@Reducer","struct Parent {","  struct State {","    var rows: IdentifiedArrayOf<Row.State>","    \/\/ ...","  }","  enum Action {","    case rows(IdentifiedActionOf<Row>)","    \/\/ ...","  }","","  var body: some Reducer<State, Action> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .forEach(\\.rows, action: \\.rows) {","      Row()","    }","  }","}"],"type":"codeListing"},{"name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We are using "},{"type":"codeVoice","code":"IdentifiedArray"},{"type":"text","text":" from our"},{"type":"text","text":" "},{"type":"reference","identifier":"http:\/\/github.com\/pointfreeco\/swift-identified-collections","isActive":true},{"type":"text","text":" library because it provides a safe"},{"type":"text","text":" "},{"type":"text","text":"and ergonomic API for accessing elements from a stable ID rather than positional indices."}]}],"style":"tip","type":"aside"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"forEach"},{"type":"text","text":" forces a specific order of operations for the child and parent features. It"},{"type":"text","text":" "},{"type":"text","text":"runs the child first, and then the parent. If the order was reversed, then it would be"},{"type":"text","text":" "},{"type":"text","text":"possible for the parent feature to remove the child state from the array, in which case the"},{"type":"text","text":" "},{"type":"text","text":"child feature would not be able to react to that action. That can cause subtle bugs."}],"type":"paragraph"},{"inlineContent":[{"text":"It is still possible for a parent feature higher up in the application to remove the child","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state from the array before the child has a chance to react to the action. In such cases a"},{"type":"text","text":" "},{"type":"text","text":"runtime warning is shown in Xcode to let you know that there’s a potential problem."}],"type":"paragraph"}]}],"sections":[],"variants":[{"paths":["\/documentation\/composablearchitecture\/reduce\/foreach(_:action:element:fileid:filepath:line:column:)-261eh"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"extendedModule":"ComposableArchitecture","externalID":"s:22ComposableArchitecture7ReducerPAAE7forEach_6action7element6fileID0H4Path4line6columnQrs011WritableKeyJ0Cy5StateQz21IdentifiedCollections0P5ArrayVyqd_1_qd__GG_s0nJ0Cy13CasePathsCore0S0Vy6ActionQzGAXyAA0pV0Oyqd_1_qd_0_GGGqd_2_yXEs12StaticStringVA6_S2utAMQyd_2_Rsd__AYQyd_2_Rsd_0_SHRd_1_s8SendableRd_1_AaBRd_2_r2_lF::SYNTHESIZED::s:22ComposableArchitecture6ReduceV","title":"forEach(_:action:element:fileID:filePath:line:column:)","symbolKind":"method","modules":[{"name":"ComposableArchitecture"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"forEach"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"ElementState"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"ElementAction"},{"kind":"text","text":", "},{"kind":"