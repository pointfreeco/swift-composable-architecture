text":", ","kind":"text"},{"text":"ID","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:SH","text":"Hashable"},{"kind":"text","text":", "},{"text":"ID","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:s8SendableP","text":"Sendable","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"Element","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:22ComposableArchitecture7ReducerP","text":"Reducer","kind":"typeIdentifier","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer"},{"text":"\n","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"toElementsState","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A writable key path from parent state to an "},{"code":"IdentifiedArray","type":"codeVoice"},{"type":"text","text":" of child"},{"text":" ","type":"text"},{"type":"text","text":"state."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A case path from parent action to an "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/IdentifiedAction","isActive":true,"type":"reference"},{"type":"text","text":" of child"},{"text":" ","type":"text"},{"text":"actions.","type":"text"}]}],"name":"toElementAction"},{"content":[{"inlineContent":[{"type":"text","text":"A reducer that will be invoked with child actions against elements of child"},{"text":" ","type":"text"},{"type":"text","text":"state."}],"type":"paragraph"}],"name":"element"}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"return-value","type":"heading","text":"Return Value","level":2},{"inlineContent":[{"text":"A reducer that combines the child reducer with the parent reducer.","type":"text"}],"type":"paragraph"}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"For example, if a parent feature holds onto an array of child states, then it can perform","type":"text"},{"type":"text","text":" "},{"text":"its core logic ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"and","type":"text"}]},{"text":" the child’s logic by using the ","type":"text"},{"type":"codeVoice","code":"forEach"},{"type":"text","text":" operator:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@Reducer","struct Parent {","  struct State {","    var rows: IdentifiedArrayOf<Row.State>","    \/\/ ...","  }","  enum Action {","    case rows(IdentifiedActionOf<Row>)","    \/\/ ...","  }","","  var body: some Reducer<State, Action> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .forEach(\\.rows, action: \\.rows) {","      Row()","    }","  }","}"]},{"name":"Tip","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"We are using ","type":"text"},{"type":"codeVoice","code":"IdentifiedArray"},{"text":" from our","type":"text"},{"type":"text","text":" "},{"identifier":"http:\/\/github.com\/pointfreeco\/swift-identified-collections","isActive":true,"type":"reference"},{"text":" library because it provides a safe","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and ergonomic API for accessing elements from a stable ID rather than positional indices."}]}],"style":"tip"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"forEach"},{"text":" forces a specific order of operations for the child and parent features. It","type":"text"},{"type":"text","text":" "},{"text":"runs the child first, and then the parent. If the order was reversed, then it would be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"possible for the parent feature to remove the child state from the array, in which case the"},{"type":"text","text":" "},{"type":"text","text":"child feature would not be able to react to that action. That can cause subtle bugs."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is still possible for a parent feature higher up in the application to remove the child"},{"text":" ","type":"text"},{"text":"state from the array before the child has a chance to react to the action. In such cases a","type":"text"},{"text":" ","type":"text"},{"text":"runtime warning is shown in Xcode to let you know that there’s a potential problem.","type":"text"}]}],"kind":"content"}],"kind":"symbol","abstract":[{"text":"Embeds a child reducer in a parent domain that works on elements of a collection in parent","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"state."}],"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reduce","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reduce\/Reducer-Implementations"]]},"metadata":{"title":"forEach(_:action:element:fileID:filePath:line:column:)","role":"symbol","modules":[{"name":"ComposableArchitecture"}],"roleHeading":"Instance Method","symbolKind":"method","externalID":"s:22ComposableArchitecture7ReducerPAAE7forEach_6action7element6fileID0H4Path4line6columnQrs011WritableKeyJ0Cy5StateQz21IdentifiedCollections0P5ArrayVyqd_1_qd__GG_s0nJ0Cy9CasePaths0S0Vy6ActionQzGAXyAA0pU0Oyqd_1_qd_0_GGGqd_2_yXEs12StaticStringVA6_S2utAMQyd_2_Rsd__AYQyd_2_Rsd_0_SHRd_1_s8SendableRd_1_AaBRd_2_r2_lF::SYNTHESIZED::s:22ComposableArchitecture6ReduceV","extendedModule":"ComposableArchitecture","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"forEach","kind":"identifier"},{"text":"<","kind":"text"},{"text":"ElementState","kind":"genericParameter"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"ElementActi