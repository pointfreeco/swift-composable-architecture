 That can cause subtle bugs.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"It automatically cancels all child effects when it detects the child’s state is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":"’d","type":"text"},{"text":" ","type":"text"},{"text":"out.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Automatically "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"s out child state when an action is sent for alerts and confirmation"},{"type":"text","text":" "},{"type":"text","text":"dialogs."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer\/ifLet(_:action:destination:fileID:filePath:line:column:)-4ub6q","isActive":true},{"type":"text","text":" for a more advanced operator suited"},{"type":"text","text":" "},{"type":"text","text":"to navigation."}]}]}],"variants":[{"paths":["\/documentation\/composablearchitecture\/combinereducers\/iflet(_:action:then:fileid:filepath:line:column:)-3kpqa"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/CombineReducers","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/CombineReducers\/Reducer-Implementations"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/CombineReducers\/ifLet(_:action:then:fileID:filePath:line:column:)-3kpqa"},"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/CombineReducers/ifLet(_:action:then:fileID:filePath:line:column:)-3kpqa":{"kind":"symbol","url":"\/documentation\/composablearchitectu