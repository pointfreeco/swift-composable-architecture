m the stack"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"It gives the child feature access to the ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/DismissEffect","type":"reference","isActive":true},{"type":"text","text":" dependency, which allows the"},{"type":"text","text":" "},{"type":"text","text":"child feature to dismiss itself without communicating with the parent."}],"type":"paragraph"}]}]}]}],"metadata":{"extendedModule":"ComposableArchitecture","roleHeading":"Instance Method","title":"forEach(_:action:destination:fileID:filePath:line:column:)","symbolKind":"method","modules":[{"name":"ComposableArchitecture"}],"role":"symbol","externalID":"s:22ComposableArchitecture7ReducerPAAE7forEach_6action11destination6fileID0H4Path4line6columnQrs011WritableKeyJ0Cy5StateQzAA05StackO0Vyqd__GG_s0nJ0Cy9CasePaths0Q0Vy6ActionQzGAWyAA0pS0Oyqd__qd_0_GGGqd_1_yXEs12StaticStringVA5_S2utAMQyd_1_Rsd__AXQyd_1_Rsd_0_AaBRd_1_r1_lF::SYNTHESIZED::s:22ComposableArchitecture6ReduceV","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"forEach","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"DestinationState"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"DestinationAction"},{"kind":"text","text":", "},{"text":"Destination","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"WritableKeyPath","preciseIdentifier":"s:s15WritableKeyPathC","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"State","preciseIdentifier":"s:22ComposableArchitecture7ReducerP5StateQa","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:22ComposableArchitecture10StackStateV","text":"StackState"},{"text":"<","kind":"text"},{"text":"DestinationState","kind":"typeIdentifier"},{"kind":"text","text":">>, "},{"text":"action","kind":"exte