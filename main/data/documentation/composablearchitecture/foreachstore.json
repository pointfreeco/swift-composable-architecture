type":"text","text":" "},{"type":"text","text":"collection index math and parent-child store communication."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For example, a todos app may define the domain and logic associated with an individual todo:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["@Reducer","struct Todo {","  struct State: Equatable, Identifiable {","    let id: UUID","    var description = \"\"","    var isComplete = false","  }","","  enum Action {","    case isCompleteToggled(Bool)","    case descriptionChanged(String)","  }","","  var body: some Reducer<State, Action> {","    \/\/ ...","  }","}"]},{"inlineContent":[{"text":"As well as a view with a domain-specific store:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct TodoView: View {","  let store: StoreOf<Todo>","  var body: some View { \/* ... *\/ }","}"]},{"inlineContent":[{"type":"text","text":"For a parent domain to work with a collection of todos, it can hold onto this collection in"},{"type":"text","text":" "},{"text":"state:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["@Reducer","struct Todos {","  struct State: Equatable {","    var todos: IdentifiedArrayOf<Todo.State> = []","  }","  \/\/ ...","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Define a case to handle actions sent to the child domain:"}]},{"code":["enum Action {","  case todos(IdentifiedActionOf<Todo>)","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Enhance its core reducer using"},{"type":"text","text":" "},{"code":"Reducer\/forEach(_:action:element:fileID:filePath:line:column:)-3dw7i","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["var body: some Reducer<State, Action> {","  Reduce { state, action in","    \/\/ ...","  }","  .forEach(\\.todos, action: \\.todos) {","    Todo()","  }","}"]},{"type":"paragraph","inlineContent":[{"text":"And finally render a list of ","type":"text"},{"type":"codeVoice","code":"TodoView"},{"type":"text","text":"s using "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/ForEachStore","isActive":true},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["ForEachStore(","  self.store.scope(state: \\.todos, action: \\.todos)",") { todoStore in","  TodoView(store: todoStore)","}"]}],"kind":"content"}],"kind":"symbol","deprecationSummary":[{"inlineContent":[{"text":"Pass 'ForEach' a store scoped to an identified array and identified action, instead. For more information, see the following article: https:\/\/pointfreeco.github.io\/swift-composable-architecture\/main\/documentation\/composablearchitecture\/migratingto1.7#Replacing-ForEachStore-with-ForEach]","type":"text"}],"type":"paragraph"}],"variants":[{"paths":["\/documentation\/composablearchitecture\/foreachstore"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"Structure","modules":[{"name":"ComposableArchitecture"}],"externalID":"s:22ComposableArchitecture12ForEachStoreV","platforms":[],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ForEachStore"}],"title":"ForEachStore","symbolKind":"struct","navigatorTitle":[{"text":"ForEachStore","kind":"identifier"}]},"abstract":[{"type":"text","text":"A Composable Architecture-friendly wrapper around "},{"type":"codeVoice","code":"ForEach"},{"type":"text","text":" that simplifies working with"},{"type":"text","text":" "},{"type":"text","text":"collections of state."}],"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/SwiftUIIntegration","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/SwiftUIDeprecations"]]},"ident