,"text":" ("},{"kind":"typeIdentifier","text":"ViewAction"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Action"},{"kind":"text","text":", "},{"kind":"externalParam","text":"removeDuplicates"},{"kind":"text","text":" "},{"kind":"internalParam","text":"isDuplicate"},{"kind":"text","text":": "},{"text":"@escaping","kind":"keyword"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","text":"ViewState"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"ViewState"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"text":", ","kind":"text"},{"text":"@","kind":"attribute"},{"text":"ViewBuilder","preciseIdentifier":"s:7SwiftUI11ViewBuilderV","kind":"attribute"},{"kind":"text","text":" "},{"text":"content","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"keyword","text":"@escaping"},{"text":" (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:22ComposableArchitecture9ViewStoreC","text":"ViewStore","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/ViewStore"},{"kind":"text","text":"<"},{"text":"ViewState","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ViewAction","kind":"typeIdentifier"},{"kind":"text","text":">) -> "},{"text":"Content","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"file","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s12StaticStringV","kind":"typeIdentifier","text":"StaticString"},{"text":" = ","kind":"text"},{"text":"#fileID","kind":"keyword"},{"kind":"text","text":", "},{"text":"line","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Su","text":"UInt"},{"text":" = ","kind":"text"},{"kind":"keyword","text":"#line"},{"kind":"text","text":")"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"store","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A store."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"A function that transforms store state into observable view state. All"},{"type":"text","text":" "},{"text":"changes to the view state will cause the ","type":"text"},{"code":"WithViewStore","type":"codeVoice"},{"text":" to re-compute its view.","type":"text"}],"type":"paragraph"}],"name":"toViewState"},{"name":"fromViewAction","content":[{"inlineContent":[{"type":"text","text":"A function that transforms view actions into store action."}],"type":"paragraph"}]},{"name":"isDuplicate","content":[{"inlineContent":[{"type":"text","text":"A function to determine when two "},{"type":"codeVoice","code":"ViewState"},{"text":" values are equal. When values","type":"text"},{"type":"text","text":" "},{"text":"are equal, repeat view computations are removed.","type":"text"}],"type":"paragraph"}]},{"name":"content","content":[{"inlineContent":[{"type":"text","text":"A function that can generate content from a view store."}],"type":"paragraph"}]},{"name":"file","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The file."}]}]},{"content":[{"inlineContent":[{"text":"The line.","type":"text"}],"type":"paragraph"}],"name":"line"}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/WithViewStore","isActive":true},{"type":"text","text":" will re-compute its body for "},{"type":"emphasis","inlineContent":[{"text":"any","type":"text"}]},{"type":"text","text":" change to the state it holds. Often the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","isActive":true},{"text":" that we want to observe holds onto a lot more state than is necessary to render a","type":"text"},{"type":"text","text":" "},{"text":"view. It may hold onto the state of child features, or internal state for its logic.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"It can be important to transform the ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","type":"reference","isActive":true},{"text":"’s state into something smaller for observation.","type":"text"},{"type":"text","text":" "},{"text":"This will help minimize the number of times your view re-computes its body, and can even avoid","type":"text"},{"type":"text","text":" "},{"type":"text","text":"certain SwiftUI bugs that happen due to over-rendering."}]},{"type":"paragraph","inlineContent":[{"text":"The way to do this is to use the ","type":"text"},{"code":"observe","type":"codeVoice"},{"text":" argument of this initializer. It allows you to","type":"text"},{"type":"text","text":" "},{"text":"turn the full state into a smaller data type, and only changes to that data type will trigger","type":"text"},{"text":" ","type":"text"},{"text":"a body re-computation.","type":"text"}]},{"inlineContent":[{"type":"text","text":"For example, if your application uses a tab view, then the root state may hold the state"},{"type":"text","text":" "},{"type":"text","text":"for each tab as well as the currently selected tab:"}],"type":"paragraph"},{"code":["@Reducer","struct AppFeature {","  enum Tab { case activity, search, profile }","  struct State {","    var activity: Activity.State","    var search: Search.State","    var profile: Profile.State","    var selectedTab: Tab","  }","  \/\/ ...","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to construct a tab view you need to observe this state because changes to"},{"text":" ","type":"text"},{"code":"selectedTab","type":"codeVoice"},{"type":"text","text":" need to make SwiftUI update the visual state of the UI. However, you do not"},{"text":" ","type":"text"},{"type":"text","text":"need to observe changes to "},{"type":"codeVoice","code":"activity"},{"type":"text","text":", "},{"code":"search","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"profile"},{"text":". Those are only necessary for","type":"text"},{"type":"text","text":" "},{"text":"those child features, and changes to that state should not cause our tab view to re-compute","type":"text"},{"text":" ","type":"text"},{"text":"itself.","type":"text"}]},{"syntax":"swift","code":["struct AppView: View {","  let store: StoreOf<AppFeature>","","  var body: some View {","    WithViewStore(self.store, observe: \\.selectedTab) { viewStore in","      TabView(selection: viewStore.binding(send: { .tabSelected($0) }) {","        ActivityView(","          store: self.store.scope(state: \\.activity, action: \\.activity)","        )","        .tag(AppFeature.Tab.activity)","        SearchView(","          store: self.store.scope(state: \\.search, action: \\.search)","        )","        .tag(AppFeature.Tab.search)","        ProfileView(","          store: self.store.scope(state: \\.profile, action: \\.profile)","        )","        .tag(AppFeature.Tab.profile)","      }","    }","  }","}"],"type":"codeListing"},{"inlineContent":[{"text":"To read more about this performance technique, read the ","type":"text"},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Performance","isActive":true},{"type":"text","text":" article."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/SwiftUIDeprecations":{"title":"Deprecations","role":"collectionGroup","abstract":[{"type":"text","text":"Review unsupported SwiftUI APIs and their replacements."}],"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/SwiftUIDeprecations","kind":"article","url":"\/documentation\/composablearchitecture\/swiftuideprecations","type":"topic"},"doc://ComposableArchitecture/documentation/ComposableArchitecture/WithViewStore":{"role":"symbol","title":"WithViewStore","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/WithViewStore","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"WithViewStore"}],"type":"topic","abstract":[{"type":"text","text":"A view helper that transforms a "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","isActive":true},{"text":" into a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/ViewStore"},{"text":" so that its state can be observed","type":"text"},{"type":"text","text":" "},{"text":"by a view builder.","type":"text"}],"kind":"symbol","navigatorTitle":[{"text":"WithViewStore","kind":"identifier"}],"url":"\/documentation\/composablearchitecture\/withviewstore","deprecated":true},"doc://ComposableArchitecture/documentation/ComposableArchitecture":{"type":"topic","abstract":[{"type":"text","text":"The Composable Architecture (TCA, for short) is a library for building applications in a consistent"},{"text":" ","type":"text"},{"text":"and understandable way, with composition, testing, and ergonomics in mind. It can be used in","type":"text"},{"text":" ","type":"text"},{"text":"SwiftUI, UIKit, and more, and on any Apple platform (iOS, macOS, tvOS, and watchOS).","type":"text"}],"url":"\/documentation\/composablearchitecture","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","kind":"symbol","title":"ComposableArchitecture","role":"collection"},"doc://ComposableArchitecture/documentation/ComposableArchitecture/Performance":{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Performance","title":"Performance","kind":"article","type":"topic","role":"article","abstract":[{"text":"Learn how t