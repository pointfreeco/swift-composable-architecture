"type":"text","text":"A store."}]}]},{"name":"toViewState","content":[{"inlineContent":[{"type":"text","text":"A function that transforms store state into observable view state. All"},{"type":"text","text":" "},{"text":"changes to the view state will cause the ","type":"text"},{"code":"WithViewStore","type":"codeVoice"},{"type":"text","text":" to re-compute its view."}],"type":"paragraph"}]},{"name":"fromViewAction","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A function that transforms view actions into store action."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A function to determine when two "},{"type":"codeVoice","code":"ViewState"},{"type":"text","text":" values are equal. When values"},{"type":"text","text":" "},{"text":"are equal, repeat view computations are removed.","type":"text"}]}],"name":"isDuplicate"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A function that can generate content from a view store.","type":"text"}]}],"name":"content"},{"name":"file","content":[{"inlineContent":[{"type":"text","text":"The file."}],"type":"paragraph"}]},{"name":"line","content":[{"type":"paragraph","inlineContent":[{"text":"The line.","type":"text"}]}]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/WithViewStore","isActive":true},{"type":"text","text":" will re-compute its body for "},{"inlineContent":[{"type":"text","text":"any"}],"type":"emphasis"},{"text":" change to the state it holds. Often the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","isActive":true,"type":"reference"},{"type":"text","text":" that we want to observe holds onto a lot more state than is necessary to render a"},{"text":" ","type":"text"},{"type":"text","text":"view. It may hold onto the state of child features, or internal state for its logic."}]},{"type":"paragraph","inlineContent":[{"text":"It can be important to transform the ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","isActive":true,"type":"reference"},{"text":"’s state into something smaller for observation.","type":"text"},{"text":" ","type":"text"},{"text":"This will help minimize the number of times your view re-computes its body, and can even avoid","type":"text"},{"type":"text","text":" "},{"type":"text","text":"certain SwiftUI bugs that happen due to over-rendering."}]},{"inlineContent":[{"text":"The way to do this is to use the ","type":"text"},{"type":"codeVoice","code":"observe"},{"type":"text","text":" argument of this initializer. It allows you to"},{"type":"text","text":" "},{"text":"turn the full state into a smaller data type, and only changes to that data type will trigger","type":"text"},{"type":"text","text":" "},{"text":"a body re-computation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For example, if your application uses a tab view, then the root state may hold the state","type":"text"},{"type":"text","text":" "},{"text":"for each tab as well as the currently selected tab:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@Reducer","struct AppFeature {","  enum Tab { case activity, search, profile }","  struct State {","    var activity: Activity.State","    var search: Search.State","    var profile: Profile.State","    var selectedTab: Tab","  }","  \/\/ ...","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to construct a tab view you need to observe this state because changes to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"selectedTab"},{"text":" need to make SwiftUI update the visual state of the UI. However, you do not","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"need to observe changes to "},{"code":"activity","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"search"},{"type":"text","text":" and "},{"type":"codeVoice","code":"profile"},{"type":"text","text":". Those are only necessary for"},{"type":"text","text":" "},{"text":"those child features, and changes to that state should not cause our tab view to re-compute","type":"text"},{"type":"text","text":" "},{"text":"itself.","type":"text"}]},{"syntax":"swift","code":["struct AppView: View {","  let store: StoreOf<AppFeature>","","  var body: some View {","    WithViewStore(self.store, observe: \\.selectedTab) { viewStore in","      TabView(selection: viewStore.binding(send: { .tabSelected($0) }) {","        ActivityView(","          store: self.store.scope(state: \\.activity, action: \\.activity)","        )","        .tag(AppFeature.Tab.activity)","        SearchView(","          store: self.store.scope(state: \\.search, action: \\.search)","        )","        .tag(AppFeature.Tab.search)","        ProfileView(","          store: self.store.scope(state: \\.profile, action: \\.profile)","        )","        .tag(AppFeature.Tab.profile)","      }","    }","  }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To read more about this performance technique, read the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Performance"},{"text":" article.","type":"text"}]}]}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/WithViewStore/init(_:observe:content:file:line:)-8g15l":{"type":"topic","url":"\/documentation\/composablearchitecture\/withviewstore\/init(_:observe:content:file:line:)-8g15l","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/WithViewStore\/init(_:observe:content:file:line:)-8g15l","role":"symbol","fragments":[{"kind":"identifier","text":"ini