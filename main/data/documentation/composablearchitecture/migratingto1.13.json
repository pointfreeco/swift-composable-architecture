{"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigrationGuides"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17.1","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.16","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.15","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.14","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.12","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.11","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.10","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.9","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.8","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.7","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.6","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.5","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.4"]}],"kind":"article","sections":[],"abstract":[{"type":"text","text":"The Composable Architecture now provides first class tools for building features in UIKit,"},{"type":"text","text":" "},{"type":"text","text":"including minimal state observation, presentation and stack navigation."}],"metadata":{"roleHeading":"Article","modules":[{"name":"ComposableArchitecture"}],"title":"Migrating to 1.13","role":"article"},"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"The Composable Architecture is now integrated with the ","type":"text"},{"identifier":"http:\/\/github.com\/pointfreeco\/swift-navigation","isActive":true,"type":"reference"},{"type":"text","text":" library,"},{"type":"text","text":" "},{"type":"text","text":"which brings powerful navigation and observation tools to UIKit. You can model your domains"},{"type":"text","text":" "},{"type":"text","text":"as concisely as possible, just as you would in SwiftUI, but then implement your view in UIKit"},{"text":" ","type":"text"},{"type":"text","text":"without losing any power."}]},{"type":"paragraph","inlineContent":[{"text":"The simplest tool to use is ","type":"text"},{"type":"codeVoice","code":"observe"},{"text":", which allows you to minimally observe changes to state in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"your feature and update the UI. Typically the best place to do this is in "},{"type":"codeVoice","code":"viewDidLoad"},{"type":"text","text":":"}]},{"syntax":"swift","code":["let store: StoreOf<Feature>","","func viewDidLoad() {","  super.viewDidLoad()","","  \/\/ ...","","  observe { [weak self] in","    countLabel.text = \"Count: \\(store.count)\"","  }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Only the state accessed in the "},{"type":"codeVoice","code":"observe"},{"type":"text","text":" trailing closure will be observed. If any other state"},{"type":"text","text":" "},{"text":"changes, the closure will not be invoked and no extra work will be performed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The library also provides powerful navigation tools for UIKit. For example, suppose you have a"},{"text":" ","type":"text"},{"text":"feature that can present a child feature (see the docs on ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/