erP5StateQa","text":"State"},{"text":", ","kind":"text"},{"text":"ElementAction","kind":"typeIdentifier"},{"kind":"text","text":" == "},{"kind":"typeIdentifier","text":"Element"},{"text":".","kind":"text"},{"text":"Action","preciseIdentifier":"s:22ComposableArchitecture7ReducerP6ActionQa","kind":"typeIdentifier","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer\/Action"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"ID"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SH","text":"Hashable"},{"kind":"text","text":", "},{"text":"ID","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Sendable","preciseIdentifier":"s:s8SendableP","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"Element","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:22ComposableArchitecture7ReducerP","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer","text":"Reducer"},{"text":"\n","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"toElementsState","content":[{"type":"paragraph","inlineContent":[{"text":"A writable key path from parent state to an ","type":"text"},{"type":"codeVoice","code":"IdentifiedArray"},{"text":" of child","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"A case path from parent action to an "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/IdentifiedAction","type":"reference","isActive":true},{"text":" of child","type":"text"},{"type":"text","text":" "},{"type":"text","text":"actions."}],"type":"paragraph"}],"name":"toElementAction"},{"name":"element","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A reducer that will be invoked with child actions against elements of child"},{"type":"text","text":" "},{"type":"text","text":"state."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The fileID."}],"type":"paragraph"}],"name":"fileID"},{"name":"filePath","content":[{"inlineContent":[{"type":"text","text":"The filePath."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The line."}]}],"name":"line"},{"content":[{"inlineContent":[{"text":"The column.","type":"text"}],"type":"paragraph"}],"name":"column"}]},{"content":[{"type":"heading","anchor":"return-value","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A reducer that combines the child reducer with the parent reducer."}]}],"kind":"content"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"For example, if a parent feature holds onto an array of child states, then it can perform","type":"text"},{"text":" ","type":"text"},{"text":"its core logic ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"and"}]},{"type":"text","text":" the child’s logic by using the "},{"code":"forEach","type":"codeVoice"},{"text":" operator:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@Reducer","struct Parent {","  struct State {","    var rows: IdentifiedArrayOf<Row.State>","    \/\/ ...","  }","  enum Action {","    case rows(IdentifiedActionOf<Row>)","    \/\/ ...","  }","","  var body: some Reducer<State, Action> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .forEach(\\.rows, action: \\.rows) {","      Row()","    }","  }","}"]},{"style":"tip","type":"aside","name":"Tip","content":[{"inlineContent":[{"type":"text","text":"We are using "},{"code":"IdentifiedArray","type":"codeVoice"},{"type":"text","text":" from our"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"http:\/\/github.com\/pointfreeco\/swift-identified-collections"},{"type":"text","text":" library because it provides a safe"},{"type":"text","text":" "},{"type":"text","text":"and ergonomic API for accessing elements from a stable ID rather than positional indices."}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"forEach","type":"codeVoice"},{"type":"text","text":" forces a specific order of operations for the child and parent features. It"},{"type":"text","text":" "},{"text":"runs the child first, and then the parent. If the order was reversed, then it would be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"possible for the parent feature to remove the child state from the array, in which case the"},{"type":"text","text":" "},{"type":"text","text":"child feature would not be able to react to that action. That can cause subtle bugs."}]},{"type":"paragraph","inlineContent":[{"text":"It is still possible for a parent feature higher up in the application to remove the child","type":"text"},{"type":"text","text":" "},{"text":"state from the array before the child has a chance to react to the action. In such cases a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"runtime warning is shown in Xcode to let you know that there’s a potential problem."}]}]}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/IdentifiedAction":{"title":"IdentifiedAction","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/IdentifiedAction","fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"text":"IdentifiedAction","kind":"identifier"}],"type":"topic","url":"\/documentation\/composablearchitecture\/identifiedaction","abstract":[{"type":"text","text":"A wrapper type for actions that can be presented in a list."}],"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"IdentifiedAction","kind":"identifier"}]},"doc://ComposableArchitecture/