"inlineContent":[{"text":"The line.","type":"text"}]}]},{"name":"column","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The column."}]}]}]},{"kind":"content","content":[{"level":2,"text":"Return Value","anchor":"return-value","type":"heading"},{"inlineContent":[{"text":"A reducer that combines the child reducer with the parent reducer.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, if a parent feature holds onto an array of child states, then it can perform"},{"type":"text","text":" "},{"type":"text","text":"its core logic "},{"inlineContent":[{"text":"and","type":"text"}],"type":"emphasis"},{"type":"text","text":" the child’s logic by using the "},{"type":"codeVoice","code":"forEach"},{"type":"text","text":" operator:"}]},{"type":"codeListing","syntax":"swift","code":["@Reducer","struct Parent {","  struct State {","    var rows: IdentifiedArrayOf<Row.State>","    \/\/ ...","  }","  enum Action {","    case rows(IdentifiedActionOf<Row>)","    \/\/ ...","  }","","  var body: some Reducer<State, Action> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .forEach(\\.rows, action: \\.rows) {","      Row()","    }","  }","}"]},{"type":"aside","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We are using "},{"type":"codeVoice","code":"IdentifiedArray"},{"type":"text","text":" from our"},{"type":"text","text":" "},{"type":"reference","identifier":"http:\/\/github.com\/pointfreeco\/swift-identified-collections","isActive":true},{"type":"text","text":" library because it provides a safe"},{"type":"text","text":" "},{"type":"text","text":"and ergonomic API for accessing elements from a stable ID rather than positional indices."}]}],"style":"tip"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"forEach"},{"text":" forces a specific order of operations for the child and parent features. It","type":"text"},{"text":" ","type":"text"},{"text":"runs the child first, and then the parent. If the order was reversed, then it would be","type":"text"},{"text":" ","type":"text"},{"text":"possible for the parent feature to remove the child state from the array, in which case the","type":"text"},{"text":" ","type":"text"},{"text":"child feature would not be able to react to that action. That can cause subtle bugs.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is still possible for a parent feature higher up in the application to remove the child"},{"type":"text","text":" "},{"type":"text","text":"state from the array before the child has a chance to react to the action. In such cases a"},{"type":"text","text":" "},{"type":"text","text":"runtime warning is shown in Xcode to let you know that there’s a potential problem."}]}]}],"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/EmptyReducer","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/EmptyReducer\/Reducer-Implementations"]]},"sections":[],"metadata":{"title":"forEach(_:action:element:fileID:filePath:line:column:)","role":"symbol","modules":[{"name":"ComposableArchitecture"}],"extendedModule":"ComposableArchitecture","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"forEach","kind":"identifier"},{"text":"<","kind":"text"},{"text":"ElementState","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"ElementAction","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"ID","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"Element","kind":"genericParameter"},{"text":">(","kind":"tex