nor":3},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There are no steps needed to migrate to 1.16 of the Composable Architecture, but there has been"},{"type":"text","text":" "},{"type":"text","text":"a change to the underlying behavior of "},{"code":".appStorage","type":"codeVoice"},{"type":"text","text":" that one should be aware of. When using"},{"type":"text","text":" "},{"code":".appStorage","type":"codeVoice"},{"type":"text","text":" with "},{"code":"@Shared","type":"codeVoice"},{"type":"text","text":", if your key does not contain the characters “.” or “@”, then changes"},{"type":"text","text":" "},{"type":"text","text":"to that key in "},{"code":"UserDefaults","type":"codeVoice"},{"type":"text","text":" will be observed using key-value observing (KVO)."},{"type":"text","text":" "},{"type":"text","text":"Otherwise, "},{"code":"NotificationCenter","type":"codeVoice"},{"type":"text","text":" will be used to observe changes."}]},{"type":"paragraph","inlineContent":[{"text":"KVO is a far more efficient way of observing changes to ","type":"text"},{"code":"UserDefaults","type":"codeVoice"},{"text":" and it works cross-process,","type":"text"},{"text":" ","type":"text"},{"text":"such as from widgets and app extensions. However, KVO does not work when the keys contain “.”","type":"text"},{"text":" ","type":"text"},{"text":"or “@”, and so in those cases we must use the cruder tool of ","type":"text"},{"code":"NotificationCenter","type":"codeVoice"},{"text":". That is not","type":"text"},{"text":" ","type":"text"},{"text":"as efficient, and it forces us to perform a thread-hop when the notification is posted before","type":"text"},{"text":" ","type":"text"},{"text":"we can update the ","type":"text"},{"code":"@Shared","type":"codeVoice"},{"text":" value. For this reason it is not possible to animate changes that are","type":"text"},{"text":" ","type":"text"},{"text":"made directly to ","type":"text"},{"code":"UserDefaults","type":"codeVoice"},{"text":":","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["withAnimation {","  \/\/ ⚠️ This will not animate any SwiftUI views using '@Shared(.appStorage(\"co.pointfree.count\"))'","  UserDefaults.standard.set(0, forKey: \"co.pointfree.count\")","}"]},{"type":"paragraph","inlineContent":[{"text":"In general, we recommend using other delimeters for your keys, such as “\/”, “:”, “-”, etc.:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["@Shared(.appStorage(\"co:pointfree:count\")) var count = 0"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/migratingto1.16"]}],"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":".appStorage"},{"type":"text","text":" strategy used with "},{"type":"codeVoice","code":"@Shared"},{"type":"text","text":" now uses key-value observing instead of"},{"type":"text","text":" "},{"type":"codeVoice","code":"NotificationCenter"},{"type":"text","text":" when possible. Learn how this may affect your code."}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture":{"type":"topic","abstract":[{"type":"text","text":"The Composable Architecture (TCA, for short) is a library for building applications in a consistent"},{"type":"text","text":" "},{"type":"text","text":"and understandable way, with composition, testing, and ergonomics in mind. It can be used in"},{"type":"text","text":" "},{"type":"text","text":"SwiftUI, UIKit, and more, and on any Apple platform (iOS, macOS, tvOS, and watchOS)."}],"kind":"symbol","role":"collection","url":"\/documentation\/composablearchitecture","title":"ComposableArchitecture","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture"},"doc://ComposableArchitecture/documentation/ComposableArchitecture/MigratingTo1.9":{"abstract":[{"type":"text","t