s:s8SendableP","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Element"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer","preciseIdentifier":"s:22ComposableArchitecture7ReducerP","text":"Reducer"},{"kind":"text","text":"\n"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"toElementsState","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A writable key path from parent state to an "},{"type":"codeVoice","code":"IdentifiedArray"},{"text":" of child","type":"text"},{"type":"text","text":" "},{"text":"state.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A case path from parent action to an "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/IdentifiedAction","type":"reference","isActive":true},{"text":" of child","type":"text"},{"type":"text","text":" "},{"type":"text","text":"actions."}]}],"name":"toElementAction"},{"content":[{"inlineContent":[{"text":"A reducer that will be invoked with child actions against elements of child","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"state."}],"type":"paragraph"}],"name":"element"},{"name":"fileID","content":[{"inlineContent":[{"type":"text","text":"The fileID."}],"type":"paragraph"}]},{"name":"filePath","content":[{"inlineContent":[{"type":"text","text":"The filePath."}],"type":"paragraph"}]},{"name":"line","content":[{"inlineContent":[{"type":"text","text":"The line."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The column.","type":"text"}],"type":"paragraph"}],"name":"column"}]},{"kind":"content","content":[{"anchor":"return-value","type":"heading","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"A reducer that combines the child reducer with the parent reducer.","type":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"For example, if a parent feature holds onto an array of child states, then it can perform"},{"text":" ","type":"text"},{"text":"its core logic ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"and","type":"text"}]},{"type":"text","text":" the child’s logic by using the "},{"code":"forEach","type":"codeVoice"},{"text":" operator:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@Reducer","struct Parent {","  struct State {","    var rows: IdentifiedArrayOf<Row.State>","    \/\/ ...","  }","  enum Action {","    case rows(IdentifiedActionOf<Row>)","    \/\/ ...","  }","","  var body: some Reducer<State, Action> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .forEach(\\.rows, action: \\.rows) {","      Row()","    }","  }","}"]},{"type":"aside","name":"Tip","style":"tip","content":[{"inlineContent":[{"type":"text","text":"We are using "},{"code":"IdentifiedArray","type":"codeVoice"},{"type":"text","text":" from our"},{"text":" ","type":"text"},{"identifier":"http:\/\/github.com\/pointfreeco\/swift-identified-collections","isActive":true,"type":"reference"},{"type":"text","text":" library because it provides a safe"},{"type":"text","text":" "},{"type":"text","text":"and ergonomic API for accessing elements from a stable ID rather than positional indices."}],"type":"paragraph"}]},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"forEach"},{"text":" forces a specific order of operations for the child and parent features. It","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"runs the child first, and then the parent. If the order was reversed, then it would be"},{"text":" ","type":"text"},{"text":"possible for the parent feature to remove the child state from the array, in which case the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"child feature would not be able to react to that action. That can cause subtle bugs."}],"type":"paragraph"},{"inlineContent":[{"text":"It is still possible for a parent feature higher up in the application to remove the child","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"state from the array before the child has a chance to react to the action. In such cases a"},{"text":" ","type":"text"},{"text":"runtime warning is shown in Xcode to let you know that there’s a potential problem.","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reduce","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reduce\/Reducer-Implementations"]]},"sections":[],"identifier":{"url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reduce\/forEach(_:action:element:fileID:filePath:line:column:)-4hrh1","interfaceLanguage":"swift"},"abstract":[{"text":"Embeds a child reducer in a parent domain that works on elements of a collection in parent","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/reduce\/foreach(_:action:element:fileid:filepath:line:column:)-4hrh1"]}],"metadata":{"symbolKind":"method","modules":[{"name":"ComposableArchitecture"}],"roleHeading":"Instance Method","extendedModule":"ComposableArchitecture","title":"forEach(_:action:element:fileID:filePath:line:column:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"forEach","kind":"identifier"},{"text":"<","kind":"text"},{"text":"ElementState","kind":"genericParameter"},{"kind":"text","text":", "},{"text":"Eleme