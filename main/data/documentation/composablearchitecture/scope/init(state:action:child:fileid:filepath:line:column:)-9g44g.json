 containing child state."}],"type":"paragraph"}],"name":"toChildState"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A case path from parent action to a case containing child actions.","type":"text"}]}],"name":"toChildAction"},{"content":[{"inlineContent":[{"type":"text","text":"A reducer that will be invoked with child actions against child state."}],"type":"paragraph"}],"name":"child"},{"content":[{"inlineContent":[{"type":"text","text":"The fileID."}],"type":"paragraph"}],"name":"fileID"},{"content":[{"inlineContent":[{"text":"The filePath.","type":"text"}],"type":"paragraph"}],"name":"filePath"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The line."}]}],"name":"line"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The column."}]}],"name":"column"}],"kind":"parameters"},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Useful for combining reducers of mutually-exclusive enum state.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["var body: some Reducer<State, Action> {","  Scope(state: \\.loggedIn, action: \\.loggedIn) {","    LoggedIn()","  }","  Scope(state: \\.loggedOut, action: \\.loggedOut) {","    LoggedOut()","  }","}"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Be careful when assembling reducers that are scoped to cases of enum state. If a"},{"type":"text","text":" "},{"type":"text","text":"scoped reducer receives a child action when its state is set to an unrelated case, it will"},{"type":"text","text":" "},{"type":"text","text":"not be able to process the action, which is considered an application logic error and will"},{"type":"text","text":" "},{"type":"text","text":"emit runtime warnings."}]},{"type":"paragraph","inlineContent":[{"text":"This can happen if another reducer in the parent domain changes the child state to an","type":"text"},{"text":" ","type":"text"},{"text":"unrelated case when it handles the action ","type":"text"},{"inlineContent":[{"text":"before","type":"text"}],"type":"emphasis"},{"text":" the scoped reducer runs. For example, a","type":"text"},{"text":" ","type":"text"},{"text":"parent may receive a dismissal action from the child domain:","type":"text"}]},{"syntax":"swift","code":["Reduce { state, action in","  switch action {","  case .loggedIn(.quitButtonTapped):","    state = .loggedOut(LoggedOut.State())","  \/\/ ...","  }","}","Scope(state: \\.loggedIn, action: \\.loggedIn) {","  LoggedIn()  \/\/ ⚠️ Logged-in domain can't handle `quitButtonTapped`","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the parent domain contains additional logic for switching between cases of child state,"},{"type":"text","text":" "},{"type":"text","text":"prefer "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer\/ifCaseLet(_:action:then:fileID:filePath:line:column:)-7sg8d"},{"type":"text","text":", which better ensures that"},{"type":"text","text":" "},{"type":"text","text":"child logic runs "},{"type":"emphasis","inlineContent":[{"text":"before","type":"text"}]},{"type":"text","text":" any parent logic can replace child state:"}]},{"syntax":"swift","code":["Reduce { state, action in","  switch action {","  case .loggedIn(.quitButtonTapped):","    state = .loggedOut(LoggedOut.State())","  \/\/ ...","  }","}",".ifCaseLet(\\.loggedIn, action: \\.loggedIn) {","  LoggedIn()  \/\/ ✅ Receives actions before its case can change","}"],"type":"codeListing"}],"type":"aside","style":"warning","name":"Warning"}],"kind":"content"}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Scope\/init(state:action:child:fileID:filePath:line:column:)-9g44g"},"metadata":{"roleHeading":"Initializer","modules":[{"name":"ComposableArchitec