"discussion","level":2},{"inlineContent":[{"text":"This version of ","type":"text"},{"type":"codeVoice","code":"forEach"},{"text":" works when the parent domain holds onto the child domain using","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackState","isActive":true,"type":"reference"},{"type":"text","text":" and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, if a parent feature models a navigation stack of child features using the"},{"text":" ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackState","isActive":true,"type":"reference"},{"type":"text","text":" and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction"},{"type":"text","text":" types, then it can perform its core logic "},{"inlineContent":[{"type":"text","text":"and"}],"type":"emphasis"},{"type":"text","text":" the logic"},{"text":" ","type":"text"},{"type":"text","text":"of each child feature using the "},{"type":"codeVoice","code":"forEach"},{"type":"text","text":" operator:"}]},{"type":"codeListing","syntax":"swift","code":["@Reducer","struct ParentFeature {","  struct State {","    var path = StackState<Path.State>()","    \/\/ ...","  }","  enum Action {","    case path(StackActionOf<Path>)","    \/\/ ...","  }","  var body: some ReducerOf<Self> {","    Reduce { state, action in","      \/\/ Core parent logic","    }","    .forEach(\\.path, action: \\.path) {","      Path()","    }","  }","}"]},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"forEach"},{"text":" operator does a number of things to make integrating parent and child features","type":"text"},{"text":" ","type":"text"},{"text":"ergonomic and enforce correctness:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"It forces a specific order of operations for the child and parent features:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"When a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction\/element(id:action:)","type":"reference"},{"type":"text","text":" action is sent it runs the"},{"type":"text","text":" "},{"type":"text","text":"child first, and then the parent. If the order was reversed, then it would be possible"},{"text":" ","type":"text"},{"type":"text","text":"for the parent feature to "},{"code":"nil","type":"codeVoice"},{"text":" out the child state, in which case the child feature","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"would not be able to react to that action. That can cause subtle bugs."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction\/popFrom(id:)"},{"type":"text","text":" action is sent it runs the parent feature"},{"type":"text","text":" "},{"text":"before the child state is popped off the stack. This gives the parent feature an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"opportunity to inspect the child state one last time before the state is removed."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"When a "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction\/push(id:state:)","isActive":true,"type":"reference"},{"text":" action is sent it runs the parent feature","type":"text"},{"type":"text","text":" "},{"type":"text","text":"after the child state is appended to the stack. This gives the parent feature an"},{"text":" ","type":"text"},{"type":"text","text":"opportunity to make extra mutations to the state after it has been added."}],"type":"paragraph"}]}]}]},{"content":[{"inlineContent":[{"type":"text","text":"It automatically cancels all child effects when it detects the child’s state is removed"},{"text":" ","type":"text"},{"type":"text","text":"from the stack"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"It gives the child feature access to the ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/DismissEffect","type":"reference","isActive":true},{"type":"text","text":" dependency, which allows the"},{"type":"text","text":" "},{"text":"child feature to dismiss itself without communicating with the parent.","type":"text"}],"type":"paragraph"}]}]}]}],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"forEach","kind":"identifier"},{"text":"<","kind":"text"},{"text":"DestinationState","kind":"genericParameter"},{"text":", ","kind":"text"},{"kind":"genericParameter","text":"DestinationAction"},{"text":", ","kind":"text"},{"kind":"genericParameter","text":"Destination"},{"kind":"text","text":">("},{"kind":"typeIdentifier","text":"WritableKeyPath","preciseIdentifier":"s:s15WritableKeyPathC"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"State","kind":"typeIdentifier","preciseIdentifier":"s:22ComposableArchitecture7ReducerP5StateQa"},{"text":", ","kind":"text"},{"text":"StackState","preciseIdentifier":"s:22ComposableArchitecture10StackStateV","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"DestinationState"},{"text":">>, ","kind":"text"},{"text":"action","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CaseKeyPath","kind":"typeIdentifier","preciseIdentifier":"s:9CasePaths0A7KeyPatha"},{"ki