/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.5","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.4"],"generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/migratingto1.6"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"modules":[{"name":"ComposableArchitecture"}],"title":"Migrating to 1.6","role":"article","roleHeading":"Article"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"The Composable Architecture is under constant development, and we are always looking for ways to"},{"type":"text","text":" "},{"type":"text","text":"simplify the library, and make it more powerful. As such, we often need to deprecate certain APIs"},{"type":"text","text":" "},{"type":"text","text":"in favor of newer ones. We recommend people update their code as quickly as possible to the newest"},{"type":"text","text":" "},{"type":"text","text":"APIs, and this article contains some tips for doing so."}],"type":"paragraph"},{"level":3,"type":"heading","text":"Asserting on action payloads","anchor":"Asserting-on-action-payloads"},{"inlineContent":[{"type":"text","text":"In version 1.4 of the library we provided a new assertion method on "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/TestStore"},{"type":"text","text":" for"},{"type":"text","text":" "},{"type":"text","text":"asserting on actions received without asserting on the payload in the action (see"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.4#Receiving-test-store-actions"},{"type":"text","text":" for more information). However, sometimes it is"},{"type":"text","text":" "},{"type":"text","text":"important to assert on the payload, especially when testing delegate actions from child features,"},{"type":"text","text":" "},{"type":"text","text":"and so that is why 1.6 introduces"},{"type":"text","text":" "},{"type":"codeVoice","code":"TestStore\/receive(_:_:timeout:assert:fileID:file:line:column:)-9jd7x"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you have code like the following for asserting that an action features sends a delegate action"},{"type":"text","text":" "},{"type":"text","text":"with a specific payload:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["await store.receive(.child(.delegate(.response(true))))"]},{"inlineContent":[{"type":"text","text":"You can now update that code to the following:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["await store.receive(\\.child.delegate.response, true)"]}]}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/MigratingTo1.9":{"type":"topic","kind":"article","title":"Migrating to 1.9","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.9","url":"\/documentation\/composablearchitecture\/migratingto1.9","abstract":[{"text":"Update your code to make use of the new ","type":"text"},{"type":"codeVoice","code":"TestStore\/send(_:assert:fileID:file:line:column:)-8877x"},{"text":"","type":"text"},{"text":" ","type":"text"},{"text":"method on ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/TestStore","type":"reference","isActive":true},{"text":" which gives a succinct syntax for sending actions with case key paths, and","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer\/dependency(_:)","type":"reference","isActive":true},{"text":" method for overriding dependencies.",