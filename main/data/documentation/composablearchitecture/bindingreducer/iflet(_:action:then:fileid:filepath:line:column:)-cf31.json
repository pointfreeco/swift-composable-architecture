pedState","content":[{"inlineContent":[{"type":"text","text":"A writable key path from parent state to a property containing optional"},{"type":"text","text":" "},{"text":"child state.","type":"text"}],"type":"paragraph"}]},{"name":"toWrappedAction","content":[{"inlineContent":[{"type":"text","text":"A case path from parent action to a case containing child actions."}],"type":"paragraph"}]},{"name":"wrapped","content":[{"type":"paragraph","inlineContent":[{"text":"A reducer that will be invoked with child actions against non-optional child","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state."}]}]},{"content":[{"inlineContent":[{"text":"The fileID.","type":"text"}],"type":"paragraph"}],"name":"fileID"},{"name":"filePath","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The filePath."}]}]},{"name":"line","content":[{"type":"paragraph","inlineContent":[{"text":"The line.","type":"text"}]}]},{"name":"column","content":[{"type":"paragraph","inlineContent":[{"text":"The column.","type":"text"}]}]}]},{"kind":"content","content":[{"anchor":"return-value","type":"heading","text":"Return Value","level":2},{"inlineContent":[{"text":"A reducer that combines the child reducer with the parent reducer.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, if a parent feature holds onto a piece of optional child state, then it can"},{"text":" ","type":"text"},{"text":"perform its core logic ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"and"}]},{"type":"text","text":" the child’s logic by using the "},{"code":"ifLet","type":"codeVoice"},{"type":"text","text":" operator:"}]},{"code":["@Reducer","struct Parent {","  struct State {","    var child: Child.State?","    \/\/ ...","  }","  enum Action {","    case child(Child.Action)","    \/\/ ...","  }","","  var body: some Reducer<State, Action> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .ifLet(\\.child, action: \\.child) {","      Child()","    }","  }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The "},{"code":"ifLet","type":"codeVoice"},{"type":"text","text":" operator does a number of things to try to enforce correctness:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It forces a specific order of operations for the child and parent features. It runs the"},{"text":" ","type":"text"},{"type":"text","text":"child first, and then the parent. If the order was reversed, then it would be possible for"},{"text":" ","type":"text"},{"type":"text","text":"the parent feature to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" out the child state, in which case the child feature would not"},{"type":"text","text":" "},{"text":"be able to react to that action. That can cause subtle bugs.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"It automatically cancels all child effects when it detects the child’s state is "},{"type":"codeVoice","code":"nil"},{"text":"’d","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"out."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Automatically ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":"s out child state when an action is sent for alerts and confirmation","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"dialogs."}]}]}]},{"inlineContent":[{"type":"text","text":"See "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer\/ifLet(_:action:destination:fileID:filePath:line:column:)-4ub6q","isActive":true,"type":"reference"},{"type":"text","text":" for a more advanced operator suited"},{"text":" ","type":"text"},{"text":"to navigat