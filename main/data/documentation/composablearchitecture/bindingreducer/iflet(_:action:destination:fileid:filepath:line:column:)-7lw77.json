"Destination","kind":"typeIdentifier"},{"text":".","kind":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer\/Action","kind":"typeIdentifier","preciseIdentifier":"s:22ComposableArchitecture7ReducerP6ActionQa","text":"Action"},{"text":", ","kind":"text"},{"text":"Destination","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Reducer","preciseIdentifier":"s:22ComposableArchitecture7ReducerP","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer","kind":"typeIdentifier"},{"text":"\n","kind":"text"}]}]},{"kind":"parameters","parameters":[{"name":"toPresentationState","content":[{"inlineContent":[{"type":"text","text":"A writable key path from parent state to a property containing child"},{"text":" ","type":"text"},{"type":"text","text":"presentation state."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A case path from parent action to a case containing child actions.","type":"text"}]}],"name":"toPresentationAction"},{"name":"destination","content":[{"type":"paragraph","inlineContent":[{"text":"A reducer that will be invoked with child actions against presented child","type":"text"},{"text":" ","type":"text"},{"text":"state.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The fileID."}]}],"name":"fileID"},{"name":"filePath","content":[{"inlineContent":[{"text":"The filePath.","type":"text"}],"type":"paragraph"}]},{"name":"line","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The line."}]}]},{"name":"column","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The column."}]}]}]},{"kind":"content","content":[{"anchor":"return-value","level":2,"text":"Return Value","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"A reducer that combines the child reducer with the parent reducer.","type":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"This version of ","type":"text"},{"type":"codeVoice","code":"ifLet"},{"text":" requires the usage of the ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Presents()","isActive":true,"type":"reference"},{"type":"text","text":" macro and"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/PresentationAction"},{"text":" type in your feature’s domain.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, if a parent feature holds onto a piece of optional child state, then it can"},{"text":" ","type":"text"},{"text":"perform its core logic ","type":"text"},{"inlineContent":[{"text":"and","type":"text"}],"type":"emphasis"},{"text":" the child’s logic by using the ","type":"text"},{"code":"ifLet","type":"codeVoice"},{"type":"text","text":" operator:"}],"type":"paragraph"},{"type":"codeListing","code":["@Reducer","struct Parent {","  @ObservableState","  struct State {","    @Presents var child: Child.State?","    \/\/ ...","  }","  enum Action {","    case child(PresentationAction<Child.Action>)","    \/\/ ...","  }","","  var body: some ReducerOf<Self> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .ifLet(\\.$child, action: \\.child) {","      Child()","    }","  }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"The "},{"code":"ifLet","type":"codeVoice"},{"text":" operator does a number of things to make integrating parent and child features","type":"text"},{"text":" ","type":"text"},{"text":"ergonomic and enforce correctness:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"It forces a specific order of operations for the child and parent features:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"text":"When a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/PresentationAction\/dismiss","type":"reference"},{"text":" action is sent, it runs the parent feature","type":"text"},{"type":"text","text":" "},{"type":"text","text":"before the child state is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"’d out. This gives the parent feature an opportunity to"},{"text":" ","type":"text"},{"text":"inspect the child state one last time before the state is cleared.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When a "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/PresentationAction\/presented(_:)","isActive":true},{"text":" action is sent it runs the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"child first, and then the parent. If the order was reversed, then it would be possible"},{"type":"text","text":" "},{"type":"text","text":"for the parent feature to "},{"code":"nil","type":"codeVoice"},{"text":" out the child state, in which case the child feature","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"would not be able to react to that action. That can cause subtle bugs."}]}]}],"type":"unorderedList"}]},{"content":[{"inlineContent":[{"text":"It automatically cancels all child effects when it detects the child’s state is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":"’d","type":"text"},{"type":"text","text":" "},{"type":"text","text":"out."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Automatically "},{"type":"codeVoice","code":"nil"},{"text":"s out child state when an action is sent for alerts and confirmation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"dialogs."}]}]},{"content":[{"inlineContent":