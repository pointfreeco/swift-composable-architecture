ext","text":" the child’s logic by using the "},{"type":"codeVoice","code":"ifLet"},{"type":"text","text":" operator:"}],"type":"paragraph"},{"code":["@Reducer","struct Parent {","  @ObservableState","  struct State {","    @Presents var child: Child.State?","    \/\/ ...","  }","  enum Action {","    case child(PresentationAction<Child.Action>)","    \/\/ ...","  }","","  var body: some ReducerOf<Self> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .ifLet(\\.$child, action: \\.child) {","      Child()","    }","  }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"ifLet"},{"type":"text","text":" operator does a number of things to make integrating parent and child features"},{"type":"text","text":" "},{"type":"text","text":"ergonomic and enforce correctness:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It forces a specific order of operations for the child and parent features:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When a "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/PresentationAction\/dismiss","type":"reference","isActive":true},{"type":"text","text":" action is sent, it runs the parent feature"},{"text":" ","type":"text"},{"type":"text","text":"before the child state is "},{"type":"codeVoice","code":"nil"},{"text":"’d out. This gives the parent feature an opportunity to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"inspect the child state one last time before the state is cleared."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"When a "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/PresentationAction\/presented(_:)","type":"reference","isActive":true},{"type":"text","text":" action is sent it runs the"},{"type":"text","text":" "},{"type":"text","text":"child first, and then the parent. If the order was reversed, then it would be possible"},{"text":" ","type":"text"},{"type":"text","text":"for the parent feature to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" out the child state, in which case the child feature"},{"type":"text","text":" "},{"type":"text","text":"would not be able to react to that action. That can cause subtle bugs."}],"type":"paragraph"}]}],"type":"unorderedList"}]},{"content":[{"inlineContent":[{"type":"text","text":"It automatically cancels all child effects when it detects the child’s state is "},{"code":"nil","type":"codeVoice"},{"text":"’d","type":"text"},{"type":"text","text":" "},{"text":"out.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Automatically "},{"code":"nil","type":"codeVoice"},{"text":"s out child state when an action is sent for alerts and confirmation","type":"text"},{"text":" ","type":"text"},{"text":"dialogs.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"It gives the child feature access to the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/DismissEffect"},{"text":" dependency, which allows the","type":"text"},{"type":"text","text":" "},{"text":"child feature to dismiss itself without communicating with the parent.","type":"text"}],"type":"paragraph"}]}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/scope\/iflet(_:action:destination:fileid:filepath:line:column:)-2u5gv"]}],"identifier":{"url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Scope\/ifLet(_:action:destination:fileID:filePath:line:column:)-2u5gv","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/S