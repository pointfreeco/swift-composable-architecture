ations"},{"kind":"parameters","parameters":[{"name":"toPresentationState","content":[{"type":"paragraph","inlineContent":[{"text":"A writable key path from parent state to a property containing child","type":"text"},{"text":" ","type":"text"},{"text":"presentation state.","type":"text"}]}]},{"name":"toPresentationAction","content":[{"type":"paragraph","inlineContent":[{"text":"A case path from parent action to a case containing child actions.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"A reducer that will be invoked with child actions against presented child","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state."}],"type":"paragraph"}],"name":"destination"}]},{"content":[{"type":"heading","anchor":"return-value","text":"Return Value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A reducer that combines the child reducer with the parent reducer."}]}],"kind":"content"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This version of "},{"type":"codeVoice","code":"ifLet"},{"text":" requires the usage of the ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Presents()","type":"reference","isActive":true},{"type":"text","text":" macro and"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/PresentationAction","isActive":true},{"text":" type in your feature’s domain.","type":"text"}]},{"inlineContent":[{"type":"text","text":"For example, if a parent feature holds onto a piece of optional child state, then it can"},{"type":"text","text":" "},{"text":"perform its core logic ","type":"text"},{"inlineContent":[{"text":"and","type":"text"}],"type":"emphasis"},{"type":"text","text":" the child’s logic by using the "},{"type":"codeVoice","code":"ifLet"},{"text":" operator:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@Reducer","struct Parent {","  @ObservableState","  struct State {","    @Presents var child: Child.State?","    \/\/ ...","  }","  enum Action {","    case child(PresentationAction<Child.Action>)","    \/\/ ...","  }","","  var body: some ReducerOf<Self> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .ifLet(\\.$child, action: \\.child) {","      Child()","    }","  }","}"]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"ifLet","type":"codeVoice"},{"type":"text","text":" operator does a number of things to make integrating parent and child features"},{"text":" ","type":"text"},{"type":"text","text":"ergonomic and enforce correctness:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"It forces a specific order of operations for the child and parent features:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"When a "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/PresentationAction\/dismiss","isActive":true},{"type":"text","text":" action is sent, it runs the parent feature"},{"text":" ","type":"text"},{"text":"before the child state is ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":"’d out. This gives the parent feature an opportunity to","type":"text"},{"text":" ","type":"text"},{"text":"inspect the child state one last time before the state is cleared.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When a "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/PresentationAction\/presented(_:)","isActive":true,"type":"reference"},{"text":" action is sent it runs the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"child first, and then the parent. If the order was reversed, then it would be possible"