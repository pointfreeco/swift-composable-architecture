aryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"As the library prepares for Swift 6 we are in the process of updating the library’s APIs for","type":"text"},{"text":" ","type":"text"},{"text":"sendability and isolation where appropriate, and doing so in a backwards compatible way. Prior","type":"text"},{"text":" ","type":"text"},{"text":"to version 1.14 of the library the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","type":"reference"},{"text":" type has only ever been meant to be used on the","type":"text"},{"text":" ","type":"text"},{"text":"main thread, but that contract was not enforced in any major way. If a store was interacted with","type":"text"},{"text":" ","type":"text"},{"text":"on a background thread a runtime warning would be emitted, but the compiler had no knowledge of","type":"text"},{"type":"text","text":" "},{"text":"the type’s isolation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"That now changes in 1.14 where ","type":"text"},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","isActive":true},{"text":" is now officially ","type":"text"},{"code":"@MainActor","type":"codeVoice"},{"text":"-isolated. This has been","type":"text"},{"text":" ","type":"text"},{"text":"done in a way that should be 100% backwards compatible, and if you have problems please open a","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"http:\/\/github.com\/pointfreeco\/swift-composable-architecture\/discussions","isActive":true},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"However, if you are using "},{"inlineContent":[{"text":"strict","type":"text"}],"type":"emphasis"},{"type":"text","text":" concurrency settings in your app, then there is one circumstance"},{"type":"text","text":" "},{"type":"text","text":"in which you may have a compilation error. If you are accessing the "},{"code":"store","type":"codeVoice"},{"type":"text","text":" in a view method or"},{"type":"text","text":" "},{"type":"text","text":"property in Xcode <16, then you may have to mark that property as "},{"code":"@MainActor","type":"codeVoice"},{"type":"text","text":":"}]},{"code":[" struct FeatureView: View {","   let store: StoreOf<Feature>"," ","   var body: some View {","     \/\/ ...","   }"," ","+  @MainActor","   var title: some View {","     Text(store.name)","   }"," }"],"type":"codeListing","syntax":"diff"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.14"},"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","isActive":true,"type":"reference"},{"type":"text","text":" type is now officially "},{"type":"codeVoice","code":"@MainActor"},{"type":"text","text":" isolated."}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/IfLetStore":{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/IfLetStore","role":"symbol","title":"IfLetStore","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"IfLetStore"}],"deprecated":true,"abstract":[{"type":"text","text":"A view that safely unwraps a store of optional state in order to show one of two views."}],"navigatorTitle":[{"kind":"identifier","text":"IfLetStore"}],"url":"\/documentation\/composablearchitecture\/ifletstore"},"doc://ComposableArchitecture/documentation/ComposableArchitecture/MigratingTo1.12":{"title":"Migrating to 1.12","url":"\/documentation\/composablearchitecture\/migratingto1.12","type":"topic","abstract":[{"text":"Take advantage of custom decoding and 