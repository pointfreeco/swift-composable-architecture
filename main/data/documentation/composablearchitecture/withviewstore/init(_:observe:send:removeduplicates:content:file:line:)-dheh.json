d":"text"},{"text":"#fileID","kind":"keyword"},{"text":", ","kind":"text"},{"text":"line","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UInt","kind":"typeIdentifier","preciseIdentifier":"s:Su"},{"text":" = ","kind":"text"},{"text":"#line","kind":"keyword"},{"text":")","kind":"text"}],"languages":["swift"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A store.","type":"text"}]}],"name":"store"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A function that transforms store state into observable view state. All","type":"text"},{"text":" ","type":"text"},{"text":"changes to the view state will cause the ","type":"text"},{"type":"codeVoice","code":"WithViewStore"},{"text":" to re-compute its view.","type":"text"}]}],"name":"toViewState"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A function that transforms view actions into store action.","type":"text"}]}],"name":"fromViewAction"},{"content":[{"inlineContent":[{"text":"A function to determine when two ","type":"text"},{"code":"ViewState","type":"codeVoice"},{"text":" values are equal. When values","type":"text"},{"text":" ","type":"text"},{"text":"are equal, repeat view computations are removed.","type":"text"}],"type":"paragraph"}],"name":"isDuplicate"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A function that can generate content from a view store.","type":"text"}]}],"name":"content"},{"content":[{"inlineContent":[{"type":"text","text":"The file."}],"type":"paragraph"}],"name":"file"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The line."}]}],"name":"line"}],"kind":"parameters"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/WithViewStore","isActive":true,"type":"reference"},{"type":"text","text":" will re-compute its body for "},{"inlineContent":[{"text":"any","type":"text"}],"type":"emphasis"},{"type":"text","text":" change to the state it holds. Often the"},{"type":"text","text":" "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","isActive":true,"type":"reference"},{"type":"text","text":" that we want to observe holds onto a lot more state than is necessary to render a"},{"type":"text","text":" "},{"type":"text","text":"view. It may hold onto the state of child features, or internal state for its logic."}]},{"type":"paragraph","inlineContent":[{"text":"It can be important to transform the ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","type":"reference","isActive":true},{"text":"’s state into something smaller for observation.","type":"text"},{"text":" ","type":"text"},{"text":"This will help minimize the number of times your view re-computes its body, and can even avoid","type":"text"},{"text":" ","type":"text"},{"text":"certain SwiftUI bugs that happen due to over-rendering.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The way to do this is to use the ","type":"text"},{"type":"codeVoice","code":"observe"},{"text":" argument of this initializer. It allows you to","type":"text"},{"text":" ","type":"text"},{"text":"turn the full state into a smaller data type, and only changes to that data type will trigger","type":"text"},{"text":" ","type":"text"},{"text":"a body re-computation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, if your application uses a tab view, then the root state may hold the state"},{"type":"text","text":" "},{"type":"text","text":"for each tab as well as the currently selected tab:"}]},{"type":"codeListing","code":["@Reducer","struct AppFeature {","  enum Tab { case activity, search, profile }","  struct State {","    var activity: Activity.State","    var search: Search.State","    var profile: Profile.State","    var selectedTab: Tab","  }","  \/\/ ...","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"In order to construct a tab view you need to observe this state because changes to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"selectedTab"},{"text":" need to make SwiftUI update the visual state of the UI. However, you do not","type":"text"},{"text":" ","type":"text"},{"text":"need to observe changes to ","type":"text"},{"type":"codeVoice","code":"activity"},{"text":", ","type":"text"},{"type":"codeVoice","code":"search"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"profile"},{"text":". Those are only necessary for","type":"text"},{"text":" ","type":"text"},{"text":"those child features, and changes to that state should not cause our tab view to re-compute","type":"text"},{"text":" ","type":"text"},{"text":"itself.","type":"text"}]},{"type":"codeListing","code":["struct AppView: View {","  let store: StoreOf<AppFeature>","","  var body: some View {","    WithViewStore(self.store, observe: \\.selectedTab) { viewStore in","      TabView(selection: viewStore.binding(send: { .tabSelected($0) }) {","        ActivityView(","          store: self.store.scope(state: \\.activity, action: \\.activity)","        )","        .tag(AppFeature.Tab.activity)","        SearchView(","          store: self.store.scope(state: \\.search, action: \\.search)","        )","        .tag(AppFeature.Tab.search)","        ProfileView(","          store: self.store.scope(state: \\.profile, action: \\.profile)","        )","        .tag(AppFeature.Tab.profile)","      }","    }","  }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"To read more about this performance technique, read the ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Performance","type":"reference","isActive":true},{"text":" article.","type":"text"}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"s