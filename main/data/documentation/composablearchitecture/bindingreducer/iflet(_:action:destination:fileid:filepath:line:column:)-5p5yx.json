[{"type":"paragraph","inlineContent":[{"text":"The column.","type":"text"}]}]}]},{"content":[{"anchor":"return-value","type":"heading","text":"Return Value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A reducer that combines the child reducer with the parent reducer."}]}],"kind":"content"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This version of "},{"type":"codeVoice","code":"ifLet"},{"type":"text","text":" requires the usage of the "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Presents()","isActive":true},{"type":"text","text":" macro and"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/PresentationAction","isActive":true},{"type":"text","text":" type in your feature’s domain."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, if a parent feature holds onto a piece of optional child state, then it can"},{"type":"text","text":" "},{"type":"text","text":"perform its core logic "},{"inlineContent":[{"text":"and","type":"text"}],"type":"emphasis"},{"type":"text","text":" the child’s logic by using the "},{"type":"codeVoice","code":"ifLet"},{"type":"text","text":" operator:"}]},{"syntax":"swift","code":["@Reducer","struct Parent {","  @ObservableState","  struct State {","    @Presents var child: Child.State?","    \/\/ ...","  }","  enum Action {","    case child(PresentationAction<Child.Action>)","    \/\/ ...","  }","","  var body: some ReducerOf<Self> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .ifLet(\\.$child, action: \\.child) {","      Child()","    }","  }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"ifLet","type":"codeVoice"},{"text":" operator does a number of things to make integrating parent and child features","type":"text"},{"text":" ","type":"text"},{"text":"ergonomic and enforce correctness:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It forces a specific order of operations for the child and parent features:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"When a ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/PresentationAction\/dismiss","isActive":true,"type":"reference"},{"text":" action is sent, it runs the parent feature","type":"text"},{"text":" ","type":"text"},{"text":"before the child state is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":"’d out. This gives the parent feature an opportunity to","type":"text"},{"text":" ","type":"text"},{"text":"inspect the child state one last time before the state is cleared.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"When a ","type":"text"},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/PresentationAction\/presented(_:)","isActive":true},{"text":" action is sent it runs the","type":"text"},{"text":" ","type":"text"},{"text":"child first, and then the parent. If the order was reversed, then it would be possible","type":"text"},{"text":" ","type":"text"},{"text":"for the parent feature to ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" out the child state, in which case the child feature","type":"text"},{"text":" ","type":"text"},{"text":"would not be able to react to that action. That can cause subtle bugs.","type":"text"}]}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It automatically cancels all child effects when it detects the child’s state is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"’d"},{"type":"text","text":" "},{"type":"text","text":"out."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Automatically "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"s out child state when an action is sent for alerts and confirmation"},{"type":"text","text":" "},{"type":"text","text":"dialogs."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It gives the child feature access to the "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/DismissEffect","type":"reference","isActive":true},{"type":"text","text":" dependency, which allows the"},{"type":"text","text":" "},{"type":"text","text":"child feature to dismiss itself without communicating with the parent."}]}]}],"type":"unorderedList"}],"kind":"content"}],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ifLet","kind":"identifier"},{"text":"<","kind":"text"},{"text":"DestinationState","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"DestinationAction","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"Destination","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"WritableKeyPath","kind":"typeIdentifier","preciseIdentifier":"s:s15WritableKeyPathC"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"State","kind":"typeIdentifier","preciseIdentifier":"s:22ComposableArchitecture7ReducerP5StateQa"},{"text":", ","kind":"text"},{"text":"PresentationState","kind":"typeIdentifier","preciseIdentifier":"s:22ComposableArchitecture17PresentationStateV"},{"text":"<","kind":"text"},{"text":"DestinationState","kind":"typeIdentifier"},{"text":">>, ","kind":"text"},{"text":"action","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CaseKeyPath","kind":"typeIdentifier","preciseIdentifier":"s:13CasePathsCore0A7KeyPatha"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Action","kind":"