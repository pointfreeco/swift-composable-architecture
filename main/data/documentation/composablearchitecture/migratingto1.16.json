{"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/migratingto1.16"]}],"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigrationGuides"]]},"seeAlsoSections":[{"identifiers":["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.19","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.18","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17.1","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.15","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.14","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.13","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.12","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.11","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.10","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.9","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.8","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.7","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.6","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.5","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.4"],"generated":true}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.16"},"metadata":{"role":"article","roleHeading":"Article","modules":[{"name":"ComposableArchitecture"}],"title":"Migrating to 1.16"},"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":".appStorage"},{"type":"text","text":" strategy used with "},{"type":"codeVoice","code":"@Shared"},{"type":"text","text":" now uses key-value observing instead of"},{"type":"text","text":" "},{"type":"codeVoice","code":"NotificationCenter"},{"type":"text","text":" when possible. Learn how this may affect your code."}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"There are no steps needed to migrate to 1.16 of the Composable Architecture, but there has been","type":"text"},{"text":" ","type":"text"},{"text":"a change to the underlying behavior of ","type":"text"},{"code":".appStorage","type":"codeVoice"},{"text":" that one should be aware of. When using","type":"text"},{"text":" ","type":"text"},{"code":".appStorage","type":"codeVoice"},{"text":" with ","type":"text"},{"code":"@Shared","type":"codeVoice"},{"text":", if your key does not contain the characters “.” or “@”, then changes","type":"text"},{"text":" ","type":"text"},{"text":"to that key in ","type":"text"},{"code":"UserDefaults","type":"codeVoice"},{"text":" will be observed using key-value observing (KVO).","type":"text"},{"text":" ","type":"text"},{"text":"Otherwise, ","type":"text"},{"code":"NotificationCenter","type":"codeVoice"},{"text":" will be used to observe changes.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"KVO is a far more efficient way of observing changes to "},{"type":"codeVoice","code":"UserDefaults"},{"type":"text","text":" and it works cross-process,"},{"type":"text","text":" "},{"type":"text","text":"such as from widgets and app extensions. However, KVO does not work when the keys contain “.”"},{"type":"text","text":" "},{"type":"text","text":"or “@”, and so in those cases we must use the cruder tool of "},{"type":"codeVoice","code":"NotificationCenter"},{"type":"text","text":". That is not"},{"type":"text","text":" "},{"type":"text","text":"as efficient, and it forces us to perform a thread-hop when the notification is posted before"},{"type":"text","text":" "},{"type":"text","text":"we can update the "},{"type":"codeVoice","code":"@Shared"},{"type":"text","text":" value. For this reason it is not possible to animate changes that are"},{"type":"text","text":" "},{"type":"text","text":"made directly to "},{"type":"codeVoice","code":"UserDefaults"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["withAnimation {","  \/\/ ⚠️ This will not animate any SwiftUI views using '@Shared(.appStorage(\"co.pointfree.count\"))'","  UserDefaults.standard.set(0, forKey: \"co.pointfree.count\")","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In general, we recommend using other delimeters for your keys, such as “\/”, “:”, “-”, etc.:"}]},{"type":"codeListing","syntax":"swift","code":["@Shared(.appStorage(\"co:pointfree:count\")) var count = 0"]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/MigratingTo1.19":{"title":"Migrating to 1.19","abstract":[{"text":"Store internals have been rewritten for performance and future features, and are now compatible with","type":"text"},{"text":" ","type":"text"},{"text":"SwiftUI’s ","type":"text"},{"type":"codeVoice","code":"@StateObject"},{"text":" property wrapper.","type":"text"}],"type":"topic","role":"article","url":"\/documentation\/composablearchitecture\/migratingto1.19","kind":"article","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.19"},"doc://ComposableArchitecture/documentation/ComposableArchitecture/IfLetStore":{"title":"IfLetStore","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IfLetStore","kin