{"sections":[],"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigrationGuides"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"article","abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":".appStorage"},{"text":" strategy used with ","type":"text"},{"type":"codeVoice","code":"@Shared"},{"text":" now uses key-value observing instead of","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NotificationCenter"},{"text":" when possible. Learn how this may affect your code.","type":"text"}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"text":"There are no steps needed to migrate to 1.16 of the Composable Architecture, but there has been","type":"text"},{"text":" ","type":"text"},{"text":"a change to the underlying behavior of ","type":"text"},{"type":"codeVoice","code":".appStorage"},{"text":" that one should be aware of. When using","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":".appStorage"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"@Shared"},{"text":", if your key does not contain the characters “.” or “@”, then changes","type":"text"},{"text":" ","type":"text"},{"text":"to that key in ","type":"text"},{"type":"codeVoice","code":"UserDefaults"},{"text":" will be observed using key-value observing (KVO).","type":"text"},{"text":" ","type":"text"},{"text":"Otherwise, ","type":"text"},{"type":"codeVoice","code":"NotificationCenter"},{"text":" will be used to observe changes.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"KVO is a far more efficient way of observing changes to ","type":"text"},{"code":"UserDefaults","type":"codeVoice"},{"text":" and it works cross-process,","type":"text"},{"text":" ","type":"text"},{"text":"such as from widgets and app extensions. However, KVO does not work when the keys contain “.”","type":"text"},{"text":" ","type":"text"},{"text":"or “@”, and so in those cases we must use the cruder tool of ","type":"text"},{"code":"NotificationCenter","type":"codeVoice"},{"text":". That is not","type":"text"},{"text":" ","type":"text"},{"text":"as efficient, and it forces us to perform a thread-hop when the notification is posted before","type":"text"},{"text":" ","type":"text"},{"text":"we can update the ","type":"text"},{"code":"@Shared","type":"codeVoice"},{"text":" value. For this reason it is not possible to animate changes that are","type":"text"},{"text":" ","type":"text"},{"text":"made directly to ","type":"text"},{"code":"UserDefaults","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["withAnimation {","  \/\/ ⚠️ This will not animate any SwiftUI views using '@Shared(.appStorage(\"co.pointfree.count\"))'","  UserDefaults.standard.set(0, forKey: \"co.pointfree.count\")","}"]},{"inlineContent":[{"type":"text","text":"In general, we recommend using other delimeters for your keys, such as “\/”, “:”, “-”, etc.:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@Shared(.appStorage(\"co:pointfree:count\")) var count = 0"]}],"kind":"content"}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.19","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.18","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17.1","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.15","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.14","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.13","doc:\/\/ComposableArch