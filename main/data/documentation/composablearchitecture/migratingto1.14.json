ext","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"However, if you are using ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"strict","type":"text"}]},{"text":" concurrency settings in your app, then there is one circumstance","type":"text"},{"text":" ","type":"text"},{"text":"in which you may have a compilation error. If you are accessing the ","type":"text"},{"code":"store","type":"codeVoice"},{"text":" in a view method or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"property in Xcode <16, then you may have to mark that property as "},{"code":"@MainActor","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"diff","code":[" struct FeatureView: View {","   let store: StoreOf<Feature>"," ","   var body: some View {","     \/\/ ...","   }"," ","+  @MainActor","   var title: some View {","     Text(store.name)","   }"," }"],"type":"codeListing"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/migratingto1.14"]}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/MigratingTo1.4":{"title":"Migrating to 1.4","role":"article","kind":"article","type":"topic","url":"\/documentation\/composablearchitecture\/migratingto1.4","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.4","abstract":[{"type":"text","text":"Update your code to make use of the "},{"isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer()","type":"reference"},{"text":" macro, and learn how to better leverage case key","type":"text"},{"text":" ","type":"text"},{"text":"paths in your features.","type":"text"}]},"doc://ComposableArchitecture/documentation/ComposableArchitecture/MigrationGuides":{"title":"Migration guides","role":"collectionGroup","kind":"article","type":"topic","url":"\/documentation\/com