ype":"text"},{"text":" ","type":"text"},{"text":"action is received:","type":"text"}]},{"type":"codeListing","code":["await store.send(.buttonTapped)","await store.receive(.response(.success(42)) {","  $0.count = 42","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Due to the variability of concurrency in Swift, sometimes a small amount of time needs to pass","type":"text"},{"text":" ","type":"text"},{"text":"before effects execute and send actions, and that is why this method suspends. The default","type":"text"},{"text":" ","type":"text"},{"text":"time waited is very small, and typically it is enough so you should be controlling your","type":"text"},{"text":" ","type":"text"},{"text":"dependencies so that they do not wait for real world time to pass (see","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/DependencyManagement","isActive":true,"type":"reference"},{"text":" for more information on how to do that).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To change the amount of time this method waits for an action, pass an explicit "},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" "},{"type":"text","text":"argument, or set the "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/TestStore\/timeout","isActive":true},{"type":"text","text":" on the "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/TestStore","isActive":true},{"type":"text","text":"."}]}],"kind":"content"}],"abstract":[{"type":"text","text":"Asserts an action was received from an effect and asserts how the state changes."}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"title":"receive(_:timeout:assert:fileID:file:line:column:)","roleHeading":"Instance Method","role":"symbol","extendedModule":"ComposableArchitecture","