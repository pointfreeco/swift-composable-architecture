ifier","text":"State","preciseIdentifier":"s:22ComposableArchitecture7ReducerP5StateQa"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"ElementAction"},{"text":" == ","kind":"text"},{"text":"Element","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Action","kind":"typeIdentifier","preciseIdentifier":"s:22ComposableArchitecture7ReducerP6ActionQa","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer\/Action"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"ID"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","text":"Hashable","preciseIdentifier":"s:SH"},{"text":", ","kind":"text"},{"text":"ID","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"text":"Sendable","preciseIdentifier":"s:s8SendableP","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"Element","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:22ComposableArchitecture7ReducerP","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer","kind":"typeIdentifier","text":"Reducer"},{"text":"\n","kind":"text"}]}]},{"parameters":[{"name":"toElementsState","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A writable key path from parent state to an "},{"type":"codeVoice","code":"IdentifiedArray"},{"text":" of child","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A case path from parent action to an "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/IdentifiedAction","type":"reference","isActive":true},{"text":" of child","type":"text"},{"type":"text","text":" "},{"type":"text","text":"actions."}]}],"name":"toElementAction"},{"name":"element","content":[{"inlineContent":[{"text":"A reducer that will be invoked with child actions against elements of child","type":"text"},{"type":"text","text":" "},{"text":"state.","type":"text"}],"type":"paragraph"}]},{"name":"fileID","content":[{"inlineContent":[{"type":"text","text":"The fileID."}],"type":"paragraph"}]},{"name":"filePath","content":[{"type":"paragraph","inlineContent":[{"text":"The filePath.","type":"text"}]}]},{"name":"line","content":[{"inlineContent":[{"type":"text","text":"The line."}],"type":"paragraph"}]},{"name":"column","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The column."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"text":"Return Value","type":"heading","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"A reducer that combines the child reducer with the parent reducer."}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, if a parent feature holds onto an array of child states, then it can perform"},{"type":"text","text":" "},{"text":"its core logic ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"and"}]},{"type":"text","text":" the child’s logic by using the "},{"type":"codeVoice","code":"forEach"},{"type":"text","text":" operator:"}]},{"syntax":"swift","type":"codeListing","code":["@Reducer","struct Parent {","  struct State {","    var rows: IdentifiedArrayOf<Row.State>","    \/\/ ...","  }","  enum Action {","    case rows(IdentifiedActionOf<Row>)","    \/\/ ...","  }","","  var body: some Reducer<State, Action> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .forEach(\\.rows, action: \\.rows) {","      Row()","    }","  }","}"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We are using "},{"code":"IdentifiedArray","type":"codeVoice"},{"type":"text","text":" from our"},{"type":"text","text":" "},{"identifier":"http:\/\/github.com\/pointfreeco\/swift-identified-collections","type":"reference","isActive":true},{"type":"text","text":" library because it provides a safe"},{"type":"text","text":" "},{"type":"text","text":"and ergonomic API for accessing elements from a stable ID rather than positional indices."}]}],"name":"Tip","style":"tip","type":"aside"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"forEach","type":"codeVoice"},{"type":"text","text":" forces a specific order of operations for the child and parent features. It"},{"type":"text","text":" "},{"text":"runs the child first, and then the parent. If the order was reversed, then it would be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"possible for the parent feature to remove the child state from the array, in which case the"},{"type":"text","text":" "},{"type":"text","text":"child feature would not be able to react to that action. That can cause subtle bugs."}]},{"inlineContent":[{"type":"text","text":"It is still possible for a parent feature higher up in the application to remove the child"},{"type":"text","text":" "},{"type":"text","text":"state from the array before the child has a chance to react to the action. In such cases a"},{"text":" ","type":"text"},{"type":"text","text":"runtime warning is shown in Xcode to let you know that there’s a potential problem."}],"type":"paragraph"}]}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/Reducer/State":{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer\/State","url":"\/documentation\/composablearchitecture\/reducer\/state","fragments":[{"kind":"keyword","text":"associatedtype"},{"text":" ","kind":"text"},{"text":"State","kind":"identifier"}],"kind":"symbol","type":"topic","title":"State","required":true,"role":"symbol","abstract":[{"text":"A type that holds the current state of the reducer.","type":"text"}]},"doc://ComposableArchitecture/documentation/ComposableArchitecture/Reducer/Action":{"fragments":[{"kind":"keyword"