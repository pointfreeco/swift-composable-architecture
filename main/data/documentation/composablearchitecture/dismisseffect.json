ePath:line:column:)-9svqb"},{"text":" operator, and then dismisses ","type":"text"},{"inlineContent":[{"type":"text","text":"that"}],"type":"emphasis"},{"type":"text","text":" "},{"type":"text","text":"feature. It performs the dismissal by either sending the "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/PresentationAction\/dismiss","type":"reference","isActive":true},{"text":" in the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"case of "},{"type":"codeVoice","code":"ifLet"},{"text":" or sending ","type":"text"},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction\/popFrom(id:)","isActive":true},{"text":" in the case of ","type":"text"},{"type":"codeVoice","code":"forEach"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also possible to dismiss the feature using an animation by providing an argument to the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"dismiss"},{"text":" function:","type":"text"}]},{"syntax":"swift","code":["case .exitButtonTapped:","  return .run { _ in await self.dismiss(animation: .default) }"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"This will cause the ","type":"text"},{"type":"codeVoice","code":"dismiss"},{"type":"text","text":" or "},{"code":"popFrom(id:)","type":"codeVoice"},{"type":"text","text":" action to be sent with the particular animation."}]},{"style":"warning","name":"Warning","type":"aside","content":[{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"@Dependency(\\.dismiss)"},{"text":" tool only works for features that are presented using","type":"text"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"code":"ifLet","type":"codeVoice"},{"type":"text","text":" operator for tree-based navigation (see "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/T