r every action sent to","type":"text"},{"text":" ","type":"text"},{"text":"the store, as well as every effect executed.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Effect instrumentation can be particularly useful for inspecting the lifecycle of long-living","type":"text"},{"type":"text","text":" "},{"type":"text","text":"effects. For example, if you start an effect ("},{"inlineContent":[{"text":"e.g.","type":"text"}],"type":"emphasis"},{"type":"text","text":", a location manager) in "},{"code":"onAppear","type":"codeVoice"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"type":"text","text":"forget to tear down the effect in "},{"type":"codeVoice","code":"onDisappear"},{"type":"text","text":", the instrument will show that the effect"},{"text":" ","type":"text"},{"text":"never completed.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/emptyreducer\/signpost(_:log:)"]}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/EmptyReducer/signpost(_:log:)":{"kind":"symbol","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/EmptyReducer\/signpost(_:log:)","role":"symbol","abstract":[{"text":"Instruments a reducer with","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/os\/logging\/recording_performance_data","type":"reference"},{"text":".","type":"text"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"signpost","kind":"identifier"},{"text":"(","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"text":"log","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:objc(cs)OS_os_log","text":"OSLog","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"_Si