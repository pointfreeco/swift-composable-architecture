nlineContent":[{"type":"text","text":"A reducer that combines the destination reducer with the parent reducer."}]}]},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"This version of "},{"code":"forEach","type":"codeVoice"},{"type":"text","text":" works when the parent domain holds onto the child domain using"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackState","type":"reference"},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"For example, if a parent feature models a navigation stack of child features using the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackState","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction"},{"type":"text","text":" types, then it can perform its core logic "},{"inlineContent":[{"text":"and","type":"text"}],"type":"emphasis"},{"type":"text","text":" the logic"},{"text":" ","type":"text"},{"text":"of each child feature using the ","type":"text"},{"code":"forEach","type":"codeVoice"},{"text":" operator:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["@Reducer","struct ParentFeature {","  struct State {","    var path = StackState<Path.State>()","    \/\/ ...","  }","  enum Action {","    case path(StackActionOf<Path>)","    \/\/ ...","  }","  var body: some ReducerOf<Self> {","    Reduce { state, action in","      \/\/ Core parent logic","    }","    .forEach(\\.path, action: \\.path) {","      Path()","    }","  }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"forEach","type":"codeVoice"},{"type":"text","text":" operator does a number of things to make integrating parent and child features"},{"type":"text","text":" "},{"type":"text","text":"ergonomic and enforce correctness:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It forces a specific order of operations for the child and parent features:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"When a ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction\/element(id:action:)","isActive":true,"type":"reference"},{"type":"text","text":" action is sent it runs the"},{"text":" ","type":"text"},{"text":"child first, and then the parent. If the order was reversed, then it would be possible","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for the parent feature to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" out the child state, in which case the child feature"},{"text":" ","type":"text"},{"text":"would not be able to react to that action. That can cause subtle bugs.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When a "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction\/popFrom(id:)","isActive":true},{"type":"text","text":" action is sent it runs the parent feature"},{"text":" ","type":"text"},{"type":"text","text":"before the child state is popped off the stack. This gives the parent feature an"},{"type":"text","text":" "},{"text":"opportunity to inspect the child state one last time before the state is removed.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When a "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction\/push(id:state:)","isActive":true},{"type":"text","text":" action is sent it runs the parent feature"},{"type":"text","text":" "},{"type":"text","text":"after the child state is appended to the stack. This gives the parent feature an"},{"type":"text","text":" "},{"text":"opportunity to make extra mutations to the state after it has been added.","type":"text"}]}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"It automatically cancels all child effects when it detects the child’s state is removed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"from the stack"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"It gives the child feature access to the "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/DismissEffect","isActive":true},{"text":" dependency, which allows the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"child feature to dismiss itself without communicating with the parent."}],"type":"paragraph"}]}]}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/swift\/optional\/foreach(_:action:destination:fileid:filepath:line:column:)-9c2qr"]}],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"forEach"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"DestinationState"},{"kind":"text","text":", "},{"text":"DestinationAction","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"Destination","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"typeIdentifier","text":"WritableKeyPath","preciseIdentifier":"s:s15WritableKeyPathC"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"Self"},{"text":".","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:22ComposableArchitecture7ReducerP5Stat