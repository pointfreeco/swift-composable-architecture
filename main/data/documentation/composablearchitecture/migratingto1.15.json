{"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"identifier":{"url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.15","interfaceLanguage":"swift"},"seeAlsoSections":[{"identifiers":["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17.1","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.16","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.14","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.13","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.12","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.11","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.10","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.9","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.8","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.7","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.6","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.5","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.4"],"generated":true}],"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigrationGuides"]]},"metadata":{"roleHeading":"Article","title":"Migrating to 1.15","modules":[{"name":"ComposableArchitecture"}],"role":"article"},"abstract":[{"type":"text","text":"The library has been completely updated for Swift 6 language mode, and now compiles in strict"},{"type":"text","text":" "},{"type":"text","text":"concurrency with no warnings or errors."}],"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"inlineContent":[{"text":"The library is now 100% Swift 6 compatible, and has been done in a way that is full backwards","type":"text"},{"type":"text","text":" "},{"type":"text","text":"compatible. If your project does not have strict concurrency warnings turned on, then updating"},{"text":" ","type":"text"},{"text":"the Composable Architecture to 1.15.0 should not cause any compilation errors. However, if you have","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"strict concurrency turned on, then you may come across a few situations you need to update."}],"type":"paragraph"},{"type":"heading","level":3,"text":"Enum cases as function references","anchor":"Enum-cases-as-function-references"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is common to use the case of enum as a function, such as mapping on an "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Effect","isActive":true,"type":"reference"},{"type":"text","text":" to bundle"},{"type":"text","text":" "},{"type":"text","text":"its output into an action:"}]},{"type":"codeListing","code":["return client.fetch()","  .map(Action.response)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"In strict concurrency mode this may fail with a message like this:","type":"text"}]},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"🛑 Converting non-sendable function value to ‘@Sendable (Value) -> Action’ may introduce data races"}]}],"type":"aside"},{"inlineContent":[{"text":"There are two ways to fix this. You can either open the closure explicitly instead of using","type":"text"},{"type":"text","text":" "},{"code":"Action.response","type":"codeVoice"},{"type":"text","text":" as a function:"}],"type":"paragraph"},{"type":"codeListing","code":["return client.fetch()","  .map { .response($0) }"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There is also an upcoming Swift feature that will fix this. You can enable it in an SPM package"},{"type":"text","text":" "},{"text":"by adding a ","type":"text"},{"code":"enableUpcomingFeature","type":"codeVoice"},{"type":"text","text":" to its Swift settings:"}]},{"type":"codeListing","syntax":"swift","code":["swiftSettings: [","  .enableUpcomingFeature(\"InferSendableFromCaptures\"),","]),"]},{"inlineContent":[{"text":"And you can ","type":"text"},{"type":"reference","identifier":"https:\/\/www.swift.org\/blog\/using-upcoming-feature-flags\/","isActive":true},{"text":" ","type":"text"},{"text":"by navigating to your project’s build settings in Xcode, and adding a new “Other Swift Flags” flag:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["-enable-upcoming-feature InferSendableFromCaptures"]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/composablearchitecture\/migratingto1.15"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/MigratingTo1.14":{"abstract":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","type":"reference"},{"type":"text","text":" type is now officially "},{"code":"@MainActor","type":"codeVoice"},{"type":"text","text":" isolated."}],"url":"\/documentation\/composablearchitecture\/migratingto1.14","kind":"article","title":"Migrating to 1.14","type":"topic","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.14","role":"article"},"doc://ComposableArchitecture/documentation/ComposableArchitecture/MigratingTo1.6":{"abstract":[{"type":"text","text":"Update your code to make use of the new"},{"text":" ","type":"text"},{"type":"codeVoice","code":"TestStore\/re