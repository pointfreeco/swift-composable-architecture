orization = {","        print(\"requestAuthorization\")","        try await speechClient.requestAuthorization()","      }","    }"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also transform "},{"inlineContent":[{"type":"text","text":"all"}],"type":"emphasis"},{"type":"text","text":" dependency values at once by using the "},{"type":"codeVoice","code":"\\.self"},{"type":"text","text":" key path:"}]},{"code":["Feature()","  .transformDependency(\\.self) { dependencyValues in","    \/\/ Access to all dependencies in here","  }"],"type":"codeListing","syntax":"swift"},{"name":"Warning","type":"aside","content":[{"inlineContent":[{"text":"The trailing closure of ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/BindingReducer\/transformDependency(_:transform:)","isActive":true,"type":"reference"},{"text":" is called for every","type":"text"},{"text":" ","type":"text"},{"text":"action sent to the reducer, and so you can expect it to be called many times in an","type":"text"},{"text":" ","type":"text"},{"text":"application’s lifecycle. This means you should typically not create dependencies in the","type":"text"},{"text":" ","type":"text"},{"text":"closure as that will cause a new dependency to be created everytime an action is sent.","type":"text"}],"type":"paragraph"}],"style":"warning"}]}],"kind":"symbol","abstract":[{"text":"Transform a reducer’s dependency value at the specified key path with the given function.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"identifier":{"url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/BindingReducer\/transformDependency(_:transform:)","interfaceLanguage":"swift"},"metadata":{"title":"transformDependency(_:transform:)","modules":[{"name":"ComposableArchitecture"}],"extendedModule":"ComposableArchitecture","roleHeading":"Instance Method","fragments":[{"text":"