{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","text":"State"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"ViewState"},{"kind":"text","text":", "},{"kind":"externalParam","text":"send"},{"kind":"text","text":" "},{"kind":"internalParam","text":"fromViewAction"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"text":" (","kind":"text"},{"kind":"typeIdentifier","text":"ViewAction"},{"text":") -> ","kind":"text"},{"text":"Action","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"attribute","text":"@"},{"kind":"attribute","text":"ViewBuilder","preciseIdentifier":"s:7SwiftUI11ViewBuilderV"},{"text":" ","kind":"text"},{"text":"content","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/ViewStore","text":"ViewStore","kind":"typeIdentifier","preciseIdentifier":"s:22ComposableArchitecture9ViewStoreC"},{"text":"<","kind":"text"},{"text":"ViewState","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ViewAction","kind":"typeIdentifier"},{"text":">) -> ","kind":"text"},{"kind":"typeIdentifier","text":"Content"},{"kind":"text","text":", "},{"text":"file","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s12StaticStringV","text":"StaticString"},{"text":" = ","kind":"text"},{"text":"#fileID","kind":"keyword"},{"kind":"text","text":", "},{"text":"line","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Su","text":"UInt","kind":"typeIdentifier"},{"text":" = ","kind":"text"},{"kind":"keyword","text":"#line"},{"text":")","kind":"text"}],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"name":"store","content":[{"type":"paragraph","inlineContent":[{"text":"A store.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"A function that transforms store state into observable view state. All","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"changes to the view state will cause the "},{"type":"codeVoice","code":"WithViewStore"},{"text":" to re-compute its view.","type":"text"}],"type":"paragraph"}],"name":"toViewState"},{"name":"fromViewAction","content":[{"type":"paragraph","inlineContent":[{"text":"A function that transforms view actions into store action.","type":"text"}]}]},{"name":"content","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A function that can generate content from a view store."}]}]},{"name":"file","content":[{"inlineContent":[{"text":"The file.","type":"text"}],"type":"paragraph"}]},{"name":"line","content":[{"type":"paragraph","inlineContent":[{"text":"The line.","type":"text"}]}]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/WithViewStore","type":"reference","isActive":true},{"type":"text","text":" will re-compute its body for "},{"type":"emphasis","inlineContent":[{"text":"any","type":"text"}]},{"text":" change to the state it holds. Often the","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store"},{"type":"text","text":" that we want to observe holds onto a lot more state than is necessary to render a"},{"type":"text","text":" "},{"text":"view. It may hold onto the state of child features, or internal state for its logic.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It can be important to transform the "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","type":"reference","isActive":true},{"type":"text","text":"’s state into something smaller for observation."},{"text":" ","type":"text"},{"text":"This will help minimize the number of times your view re-computes its body, and can even avoid","type":"text"},{"type":"text","text":" "},{"type":"text","text":"certain SwiftUI bugs that happen due to over-rendering."}]},{"inlineContent":[{"type":"text","text":"The way to do this is to use the "},{"type":"codeVoice","code":"observe"},{"type":"text","text":" argument of this initializer. It allows you to"},{"type":"text","text":" "},{"text":"turn the full state into a smaller data type, and only changes to that data type will trigger","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a body re-computation."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, if your application uses a tab view, then the root state may hold the state"},{"type":"text","text":" "},{"type":"text","text":"for each tab as well as the currently selected tab:"}],"type":"paragraph"},{"type":"codeListing","code":["@Reducer","struct AppFeature {","  enum Tab { case activity, search, profile }","  struct State {","    var activity: Activity.State","    var search: Search.State","    var profile: Profile.State","    var selectedTab: Tab","  }","  \/\/ ...","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"In order to construct a tab view you need to observe this state because changes to"},{"type":"text","text":" "},{"code":"selectedTab","type":"codeVoice"},{"text":" need to make SwiftUI update the visual state of the UI. However, you do not","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"need to observe changes to "},{"code":"activity","type":"codeVoice"},{"text":", ","type":"text"},{"code":"search","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"profile"},{"type":"text","text":". Those are only necessary for"},{"text":" ","type":"text"},{"type":"text","text":"those child features, and changes to that state should not cause our tab view to re-compute"},{"text":" ","type":"text"},{"type":"text","text":"itself."}],"type":"paragraph"},{"code":["struct AppView: View {","  let store: StoreOf<AppFeature>","","  var body: some View {","    WithViewStore(self.store, observe: \\.selectedTab) { viewStore in","      TabView(selection: viewStore.binding(send: { .tabSelected($0) }) {","        ActivityView(","          store: self.store.scope(state: \\.activity, action: \\.activity)","        )","        .tag(AppFeature.Tab.activity)","        SearchView(","          store: self.store.scope(state: \\.search, action: \\.search)","        )","        .tag(AppFeature.Tab.search)","        ProfileView(","          store: self.store.scope(state: \\.profile, action: \\.profile)","        )","        .tag(AppFeature.Tab.profile)","      }","    }","  }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To read more about this performance technique, read the "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Performance","isActive":true,"type":"reference"},{"type":"text","text":" article."}]}]}],"metadata":{"title":"init(_:observe:send:content:file:line:)","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"<"},{"text":"State","kind":"genericParameter"},{"kind":"text","text":", "},{"text":"Action","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"Store","kind":"typeIdentifier","preciseIdentifier":"s:22ComposableArchitecture5StoreC"},{"text":"<","kind":"text"},{"text":"State","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Action"},{"kind":"text","text":">, "},{"text":"observe","kind":"externalParam"},{"kind":"text","text":": ("},{"text":"State","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"ViewState","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"send","kind":"externalParam"},{"text":": (","kind":"text"},{"text":"ViewAction","kind":"typeI