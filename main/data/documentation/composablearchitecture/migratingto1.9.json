","type":"text"}]},{"type":"codeListing","syntax":"diff","code":["-store.receive(.child(.presented(.response(.success(\"Hello\")))))","+store.receive(\\.child.response.success)"]},{"inlineContent":[{"text":"While version 1.6 of the library introduced the ability to assert against the payload of a received","type":"text"},{"type":"text","text":" "},{"text":"action:","type":"text"}],"type":"paragraph"},{"code":["store.receive(\\.child.presented.success, \"Hello\")"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Version 1.9 introduces similar affordances for ","type":"text"},{"inlineContent":[{"type":"text","text":"sending"}],"type":"emphasis"},{"text":" actions to test stores via","type":"text"},{"type":"text","text":" "},{"code":"TestStore\/send(_:assert:fileID:file:line:column:)-8877x","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/TestStore\/send(_:_:assert:fileID:file:line:column:)","type":"reference"},{"type":"text","text":". These methods can significantly simplify"},{"text":" ","type":"text"},{"text":"integration-style tests that send deeply-nested actions to child features, and provide symmetry to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"how actions are received:"}]},{"type":"codeListing","code":["-store.send(.path(.element(id: 0, action: .destination(.presented(.record(.startButtonTapped))))))","+store.send(\\.path[id: 0].destination.record.startButtonTapped)"," store.receive(\\.path[id: 0].destination.record.timerTick)"],"syntax":"diff"},{"content":[{"inlineContent":[{"type":"text","text":"Case key paths offer specialized syntax for many different action types."}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/P