xt":" as a function:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["return client.fetch()","  .map { .response($0) }"]},{"type":"paragraph","inlineContent":[{"text":"There is also an upcoming Swift feature that will fix this. You can enable it in an SPM package","type":"text"},{"text":" ","type":"text"},{"text":"by adding a ","type":"text"},{"code":"enableUpcomingFeature","type":"codeVoice"},{"text":" to its Swift settings:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["swiftSettings: [","  .enableUpcomingFeature(\"InferSendableFromCaptures\"),","]),"]},{"inlineContent":[{"type":"text","text":"And you can "},{"isActive":true,"type":"reference","identifier":"https:\/\/www.swift.org\/blog\/using-upcoming-feature-flags\/"},{"type":"text","text":" "},{"type":"text","text":"by navigating to your project’s build settings in Xcode, and adding a new “Other Swift Flags” flag:"}],"type":"paragraph"},{"syntax":null,"code":["-enable-upcoming-feature InferSendableFromCaptures"],"type":"codeListing"}]}],"identifier":{"url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.15","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/migratingto1.15"]}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/MigratingTo1.17":{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17","abstract":[{"type":"text","text":"The "},{"code":"@Shared","type":"codeVoice"},{"type":"text","text":" property wrapper and related tools have been extracted to their own"},{"type":"text","text":" "},{"type":"text","text":"library so that they can be used in non-Composable Architecture applications. This a"},{"type":"text","text":" "},{"type":"text","text":"backwards compatible change, but some new deprecations have been introduced."}],"title":"Migrating to 1.17","role":"article","url":"