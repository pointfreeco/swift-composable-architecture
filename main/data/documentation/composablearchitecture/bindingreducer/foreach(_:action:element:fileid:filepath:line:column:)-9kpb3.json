ture\/documentation\/ComposableArchitecture\/Reducer\/State"},{"text":", ","kind":"text"},{"text":"ElementAction","kind":"typeIdentifier"},{"kind":"text","text":" == "},{"text":"Element","kind":"typeIdentifier"},{"kind":"text","text":"."},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer\/Action","kind":"typeIdentifier","preciseIdentifier":"s:22ComposableArchitecture7ReducerP6ActionQa","text":"Action"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"ID"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:SH","text":"Hashable","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"ID"},{"kind":"text","text":" : "},{"text":"Sendable","preciseIdentifier":"s:s8SendableP","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"Element","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer","preciseIdentifier":"s:22ComposableArchitecture7ReducerP","kind":"typeIdentifier","text":"Reducer"},{"text":"\n","kind":"text"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A writable key path from parent state to an ","type":"text"},{"code":"IdentifiedArray","type":"codeVoice"},{"text":" of child","type":"text"},{"type":"text","text":" "},{"text":"state.","type":"text"}]}],"name":"toElementsState"},{"name":"toElementAction","content":[{"inlineContent":[{"type":"text","text":"A case path from parent action to an "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/IdentifiedAction","isActive":true},{"text":" of child","type":"text"},{"type":"text","text":" "},{"type":"text","text":"actions."}],"type":"paragraph"}]},{"name":"element","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A reducer that will be invoked with child actions against elements of child"},{"type":"text","text":" "},{"type":"text","text":"state."}]}]}]},{"content":[{"text":"Return Value","level":2,"anchor":"return-value","type":"heading"},{"inlineContent":[{"type":"text","text":"A reducer that combines the child reducer with the parent reducer."}],"type":"paragraph"}],"kind":"content"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"For example, if a parent feature holds onto an array of child states, then it can perform","type":"text"},{"type":"text","text":" "},{"text":"its core logic ","type":"text"},{"inlineContent":[{"text":"and","type":"text"}],"type":"emphasis"},{"text":" the child’s logic by using the ","type":"text"},{"code":"forEach","type":"codeVoice"},{"text":" operator:","type":"text"}]},{"code":["@Reducer","struct Parent {","  struct State {","    var rows: IdentifiedArrayOf<Row.State>","    \/\/ ...","  }","  enum Action {","    case rows(IdentifiedActionOf<Row>)","    \/\/ ...","  }","","  var body: some Reducer<State, Action> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .forEach(\\.rows, action: \\.rows) {","      Row()","    }","  }","}"],"type":"codeListing","syntax":"swift"},{"name":"Tip","style":"tip","content":[{"inlineContent":[{"text":"We are using ","type":"text"},{"code":"IdentifiedArray","type":"codeVoice"},{"type":"text","text":" from our"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"http:\/\/github.com\/pointfreeco\/swift-identified-collections"},{"type":"text","text":" library because it provides a safe"},{"text":" ","type":"text"},{"type":"text","text":"and ergonomic API for accessing elements from a stable ID rather than positional indices."}],"type":"paragraph"}],"type":"aside"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"forEach"},{"text":" forces a specific order of operations for the child and parent features. It","type":"text"},{"type":"text","text":" "},{"type":"text","text":"runs the child first, and then the parent. If the order was reversed, then it would be"},{"text":" ","type":"text"},{"type":"text","text":"possible for the parent feature to remove the child state from the array, in which case the"},{"type":"text","text":" "},{"text":"child feature would not be able to react to that action. That can cause subtle bugs.","type":"text"}]},{"inlineContent":[{"text":"It is still possible for a parent feature higher up in the application to remove the child","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"state from the array before the child has a chance to react to the action. In such cases a"},{"type":"text","text":" "},{"type":"text","text":"runtime warning is shown in Xcode to let you know that there’s a potential problem."}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/BindingReducer\/forEach(_:action:element:fileID:filePath:line:column:)-9kpb3"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/bindingreducer\/foreach(_:action:element:fileid:filepath:line:column:)-9kpb3"]}],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"forEach","kind":"identifier"},{"kind":"text","text":"<"},{"text":"ElementState","kind":"genericParameter"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"ElementAction"},{"text":", ","kind":"text"},{"kind":"genericParameter","text":"ID"},{"kind":"text","text":", "},{"text":"Element","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"WritableKeyPath","kind":"typeIdentifier","preciseIdentifier":"s:s15WritableKeyPathC"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"State","kind":"typeIdentifier","preciseIdentifier":"s:22Composab