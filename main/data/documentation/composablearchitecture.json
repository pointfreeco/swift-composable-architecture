{"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture"]}],"sections":[],"seeAlsoSections":[{"identifiers":["https:\/\/www.pointfree.co\/collections\/composable-architecture"],"abstract":[{"text":"The collection of videos from ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/www.pointfree.co"},{"text":" that dive deep into the","type":"text"},{"text":" ","type":"text"},{"text":"development of the library.","type":"text"}],"anchor":"Related-Documentation","title":"Related Documentation"}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Additional-Resources","text":"Additional Resources"},{"items":[{"content":[{"inlineContent":[{"isActive":true,"identifier":"https:\/\/github.com\/pointfreeco\/swift-composable-architecture","type":"reference"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/github.com\/pointfreeco\/swift-composable-architecture\/discussions","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/www.pointfree.co\/collections\/composable-architecture","type":"reference"}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This library provides a few core tools that can be used to build applications of varying purpose and"},{"type":"text","text":" "},{"type":"text","text":"complexity. It provides compelling stories that you can follow to solve many problems you encounter"},{"type":"text","text":" "},{"type":"text","text":"day-to-day when building applications, such as:"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"State management","type":"text"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"text":"How to manage the state of your application using simple value types, and sh