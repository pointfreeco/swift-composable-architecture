works when the parent domain holds onto the child domain using","type":"text"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackState"},{"text":" and ","type":"text"},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, if a parent feature models a navigation stack of child features using the"},{"text":" ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackState","type":"reference","isActive":true},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction"},{"type":"text","text":" types, then it can perform its core logic "},{"inlineContent":[{"type":"text","text":"and"}],"type":"emphasis"},{"type":"text","text":" the logic"},{"type":"text","text":" "},{"type":"text","text":"of each child feature using the "},{"type":"codeVoice","code":"forEach"},{"text":" operator:","type":"text"}]},{"code":["@Reducer","struct ParentFeature {","  struct State {","    var path = StackState<Path.State>()","    \/\/ ...","  }","  enum Action {","    case path(StackActionOf<Path>)","    \/\/ ...","  }","  var body: some ReducerOf<Self> {","    Reduce { state, action in","      \/\/ Core parent logic","    }","    .forEach(\\.path, action: \\.path) {","      Path()","    }","  }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"forEach"},{"type":"text","text":" operator does a number of things to make integrating parent and child features"},{"type":"text","text":" "},{"type":"text","text":"ergonomic and enforce correctness:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It forces a specific order of operations for the child and parent features:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"When a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction\/element(id:action:)"},{"text":" action is sent it runs the","type":"text"},{"type":"text","text":" "},{"text":"child first, and then the parent. If the order was reversed, then it would be possible","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for the parent feature to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" out the child state, in which case the child feature"},{"text":" ","type":"text"},{"type":"text","text":"would not be able to react to that action. That can cause subtle bugs."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"When a "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction\/popFrom(id:)","isActive":true,"type":"reference"},{"type":"text","text":" action is sent it runs the parent feature"},{"type":"text","text":" "},{"type":"text","text":"before the child state is popped off the stack. This gives the parent feature an"},{"type":"text","text":" "},{"type":"text","text":"opportunity to inspect the child state one last time before the state is removed."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"When a ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction\/push(id:state:)","type":"reference","isActive":true},{"type":"text","text":" action is sent it runs the parent feature"},{"type":"text","text":" "},{"type":"text","text":"after the child state is appended to the stack. This gives the parent feature an"},{"type":"text","text":" "},{"type":"text","text":"opportunity to make extra mutations to the state after it has been added."}]}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"It automatically cancels all child effects when it detects the child’s state is removed","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"from the stack"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"It gives the child feature access to the "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/DismissEffect","isActive":true,"type":"reference"},{"type":"text","text":" dependency, which allows the"},{"type":"text","text":" "},{"text":"child feature to dismiss itself without communicating with the parent.","type":"text"}],"type":"paragraph"}]}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/EmptyReducer\/forEach(_:action:destination:fileID:filePath:line:column:)-3iew6"},"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/StackAction":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"StackAction"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"text":"StackAction","kind":"identifier"}],"kind":"symbol","abstract":[{"text":"A wrapper type for actions that can be presented in a navigation stack.","type":"text"}],"url":"\/documentation\/composablearchitecture\/stackaction","role":"symbol","title":"StackAction","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackAction"},"doc://ComposableArchitecture/documentation/ComposableArchitecture/StackAction/push(id:state:)":{"fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"push"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"id"},{"kind":"text","text":": "},{"text":"StackElementID","kind":"typeIdentifier","preciseIdentifier":"s:22ComposableArchitecture14StackElementIDV"},{"te