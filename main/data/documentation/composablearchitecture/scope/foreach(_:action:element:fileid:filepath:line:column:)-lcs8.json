ext":", ","kind":"text"},{"text":"Element","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Reducer","kind":"typeIdentifier","preciseIdentifier":"s:22ComposableArchitecture7ReducerP","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer"},{"text":"\n","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A writable key path from parent state to an ","type":"text"},{"code":"IdentifiedArray","type":"codeVoice"},{"text":" of child","type":"text"},{"text":" ","type":"text"},{"text":"state.","type":"text"}]}],"name":"toElementsState"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A case path from parent action to an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/IdentifiedAction","type":"reference"},{"text":" of child","type":"text"},{"text":" ","type":"text"},{"text":"actions.","type":"text"}]}],"name":"toElementAction"},{"content":[{"inlineContent":[{"type":"text","text":"A reducer that will be invoked with child actions against elements of child"},{"type":"text","text":" "},{"type":"text","text":"state."}],"type":"paragraph"}],"name":"element"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The fileID."}]}],"name":"fileID"},{"content":[{"inlineContent":[{"type":"text","text":"The filePath."}],"type":"paragraph"}],"name":"filePath"},{"content":[{"inlineContent":[{"type":"text","text":"The line."}],"type":"paragraph"}],"name":"line"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The column."}]}],"name":"column"}],"kind":"parameters"},{"content":[{"level":2,"text":"Return Value","anchor":"return-value","type":"heading"},{"inlineContent":[{"text":"A reducer that combines the child reducer with the parent reducer.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"For example, if a parent feature holds onto an array of child states, then it can perform","type":"text"},{"text":" ","type":"text"},{"text":"its core logic ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"and"}]},{"text":" the child’s logic by using the ","type":"text"},{"type":"codeVoice","code":"forEach"},{"text":" operator:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["@Reducer","struct Parent {","  struct State {","    var rows: IdentifiedArrayOf<Row.State>","    \/\/ ...","  }","  enum Action {","    case rows(IdentifiedActionOf<Row>)","    \/\/ ...","  }","","  var body: some Reducer<State, Action> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .forEach(\\.rows, action: \\.rows) {","      Row()","    }","  }","}"],"type":"codeListing"},{"name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We are using "},{"type":"codeVoice","code":"IdentifiedArray"},{"type":"text","text":" from our"},{"type":"text","text":" "},{"type":"reference","identifier":"http:\/\/github.com\/pointfreeco\/swift-identified-collections","isActive":true},{"type":"text","text":" library because it provides a safe"},{"type":"text","text":" "},{"type":"text","text":"and ergonomic API for accessing elements from a stable ID rather than positional indices."}]}],"type":"aside","style":"tip"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"forEach"},{"type":"text","text":" forces a specific order of operations for the child and parent features. It"},{"type":"text","text":" "},{"type":"text","text":"runs the child first, and then the parent. If the order was reversed, then it would be"},{"type":"text","text":" "},{"type":"text","text":"possible for the parent feature to remove the child state from the array, in which case the"},{"type":"text","text":" "},{"type":"text","text":"child feature would not be able to react to that action. That can cause subtle bugs."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It is still possible for a parent feature higher up in the application to remove the child"},{"type":"text","text":" "},{"type":"text","text":"state from the array before the child has a chance to react to the action. In such cases a"},{"type":"text","text":" "},{"type":"text","text":"runtime warning is shown in Xcode to let you know that there’s a potential problem."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/scope\/foreach(_:action:element:fileid:filepath:line:column:)-lcs8"]}],"identifier":{"url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Scope\/forEach(_:action:element:fileID:filePath:line:column:)-lcs8","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Scope","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Scope\/Reducer-Implementations"]]},"abstract":[{"type":"text","text":"Embeds a child reducer in a parent domain that works on elements of a collection in parent"},{"type":"text","text":" "},{"type":"text","text":"state."}],"metadata":{"extendedModule":"ComposableArchitecture","roleHeading":"Instance Method","modules":[{"name":"ComposableArchitecture"}],"title":"forEach(_:action:element:fileID:filePath:line:column:)","externalID":"s:22ComposableArchitecture7ReducerPAAE7forEach_6action7element6fileID0H4Path4line6columnQrs011WritableKeyJ0Cy5StateQz21IdentifiedCollections0P5ArrayVyqd_1_qd__GG_s0nJ0Cy13CasePathsCore0S0Vy6ActionQzGAXyAA0pV0Oyqd_1_qd_0_GGGqd_2_yXEs12StaticStringVA6_S2utAMQyd_2_Rsd__AYQyd_2_Rsd_0_SHRd_1_s8SendableRd_1