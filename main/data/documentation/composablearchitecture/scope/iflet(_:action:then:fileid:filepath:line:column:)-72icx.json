t","type":"codeVoice"},{"type":"text","text":" operator does a number of things to try to enforce correctness:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"It forces a specific order of operations for the child and parent features. It runs the","type":"text"},{"type":"text","text":" "},{"text":"child first, and then the parent. If the order was reversed, then it would be possible for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the parent feature to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" out the child state, in which case the child feature would not"},{"type":"text","text":" "},{"type":"text","text":"be able to react to that action. That can cause subtle bugs."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"It automatically cancels all child effects when it detects the child’s state is ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":"’d"},{"type":"text","text":" "},{"type":"text","text":"out."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Automatically "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"s out child state when an action is sent for alerts and confirmation"},{"type":"text","text":" "},{"text":"dialogs.","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer\/ifLet(_:action:destination:fileID:filePath:line:column:)-4ub6q"},{"text":" for a more advanced operator suited","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to navigation."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/scope\/iflet(_:action:then:fileid:filepath:line:column:)-72icx"]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ComposableArchitecture\/docum