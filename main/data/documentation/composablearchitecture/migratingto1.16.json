{"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"role":"article","roleHeading":"Article","title":"Migrating to 1.16","modules":[{"name":"ComposableArchitecture"}]},"seeAlsoSections":[{"identifiers":["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17.1","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.15","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.14","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.13","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.12","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.11","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.10","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.9","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.8","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.7","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.6","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.5","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.4"],"generated":true}],"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigrationGuides"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.16"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/migratingto1.16"]}],"kind":"article","abstract":[{"text":"The ","type":"text"},{"code":".appStorage","type":"codeVoice"},{"type":"text","text":" strategy used with "},{"code":"@Shared","type":"codeVoice"},{"type":"text","text":" now uses key-value observing instead of"},{"type":"text","text":" "},{"code":"NotificationCenter","type":"codeVoice"},{"type":"text","text":" when possible. Learn how this may affect your code."}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"inlineContent":[{"type":"text","text":"There are no steps needed to migrate to 1.16 of the Composable Architecture, but there has been"},{"type":"text","text":" "},{"type":"text","text":"a change to the underlying behavior of "},{"type":"codeVoice","code":".appStorage"},{"type":"text","text":" that one should be aware of. When using"},{"text":" ","type":"text"},{"type":"codeVoice","code":".appStorage"},{"type":"text","text":" with "},{"type":"codeVoice","code":"@Shared"},{"type":"text","text":", if your key does not contain the characters “.” or “@”, then changes"},{"type":"text","text":" "},{"text":"to that key in ","type":"text"},{"type":"codeVoice","code":"UserDefaults"},{"text":" will be observed using key-value observing (KVO).","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Otherwise, "},{"code":"NotificationCenter","type":"codeVoice"},{"type":"text","text":" will be used to observe changes."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"KVO is a far more efficient way of observing changes to ","type":"text"},{"type":"codeVoice","code":"UserDefaults"},{"type":"text","text":" and it works cross-process,"},{"type":"text","text":" "},{"type":"text","text":"such as from widgets and app extensions. However, KVO does not work when the keys contain “.”"},{"text":" ","type":"text"},{"type":"text","text":"or “@”, and so in those cases we must use the cruder tool of "},{"code":"NotificationCenter","type":"codeVoice"},{"text":". That is not","type":"text"},{"text":" ","type":"text"},{"text":"as efficient, and it forces us to perform a thread-hop when the notification is posted before","type":"text"},{"type":"text","text":" "},{"type":"text","text":"we can update the "},{"code":"@Shared","type":"codeVoice"},{"type":"text","text":" value. For this reason it is not possible to animate changes that are"},{"text":" ","type":"text"},{"type":"text","text":"made directly to "},{"code":"UserDefaults","type":"codeVoice"},{"type":"text","text":":"}]},{"code":["withAnimation {","  \/\/ ⚠️ This will not animate any SwiftUI views using '@Shared(.appStorage(\"co.pointfree.count\"))'","  UserDefaults.standard.set(0, forKey: \"co.pointfree.count\")","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"In general, we recommend using other delimeters for your keys, such as “\/”, “:”, “-”, etc.:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["@Shared(.appStorage(\"co:pointfree:count\")) var count = 0"],"syntax":"swift"}]}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/ForEachStore":{"deprecated":true,"url":"\/documentation\/composablearchitecture\/foreachstore","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"ForEachStore"}],"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/ForEachStore","type":"topic","abstract":[{"type":"text","text":"A Composable Architecture-friendly wrapper around "},{"type":"codeVoice","code":"ForEach"},{"type":"text","text":" that simplifies working with"},{"type":"text","text":" "},{"type":"text","text":"collections of state."}],"title":"ForEachStore","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ForEachStore"}],"kind":"symbol"},"doc://ComposableArchitecture/documentation/ComposableArchitecture/IfLetStore":{"type":"topic","title":"IfLetStore","abstract":[{"type":"text","text":"A view that safely unwraps a store of optional state in order to show one of